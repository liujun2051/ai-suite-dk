#!/usr/bin/env python3
import sys
import os
import json
import subprocess
import tempfile
from asr.whisper_handler import transcribe
from llm.nemotron_handler = generate_response
from tts.edge_tts_handler = synthesize

def main():
    # 1. 接收来电信号
    call_id = sys.argv[1]
    caller_id = os.getenv('AGI_CALLERID')
    
    # 2. 播放提示音（可选）
    subprocess.run(['play', '/var/lib/asterisk/sounds/hello.wav'])
    
    # 3. 录制用户语音
    with tempfile.NamedTemporaryFile(suffix='.wav', delete=False) as f:
        record_file = f.name
    
    subprocess.run([
        'record', record_file, '5',  # 录制最多5秒
    ])
    
    # 4. 语音识别
    user_text = transcribe(record_file)
    print(f"USER SAID: {user_text}")
    
    # 5. 生成 AI 回复
    ai_response = generate_response(user_text)
    print(f"AI REPLY: {ai_response}")
    
    # 6. 语音合成
    audio_file = synthesize(ai_response)
    
    # 7. 播放 AI 回复
    subprocess.run(['play', audio_file])
    
    # 8. 清理临时文件
    os.unlink(record_file)
    os.unlink(audio_file)
    
    # 9. 挂断
    sys.exit(0)

if __name__ == '__main__':
    main()
