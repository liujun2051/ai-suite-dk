# ==================== 处理器 ====================

class CallAnalyticsProcessor:
    def __init__(self):
        self.start_time = None
        self.user_utterances = []
        self.agent_utterances = []
        
    async def process_frame(self, frame, direction):
        await super().process_frame(frame, direction)
        if isinstance(frame, UserStartedSpeakingFrame) and not self.start_time:
            self.start_time = datetime.now()
        elif isinstance(frame, UserStoppedSpeakingFrame) and self.start_time:
            duration = (datetime.now() - self.start_time).total_seconds()
            logger.info(f"用户停止说话，通话时长约: {duration:.1f}秒")
        elif isinstance(frame, TranscriptionFrame):
            if hasattr(frame, 'user_id') and frame.user_id == "user":
                self.user_utterances.append({"text": frame.text})
                logger.info(f"用户说: {frame.text}")
            else:
                self.agent_utterances.append({"text": frame.text})
                logger.info(f"AI说: {frame.text}")
        await self.push_frame(frame, direction)

class CallResultProcessor:
    def __init__(self):
        self.call_info = {}
        
    async def process_frame(self, frame, direction):
        await super().process_frame(frame, direction)
        await self.push_frame(frame, direction)

# ==================== 主应用 ====================

async def main():
    logger.info("🚀 启动 Pipecat 电话外呼系统...")
    
    transport = TelnyxTransport(
        TelnyxParams(
            api_key=TELNYX_API_KEY,
            phone_number=TELNYX_PHONE_NUMBER,
        )
    )
    
    stt = DeepgramSTTService(
        api_key=DEEPGRAM_API_KEY,
        live_options={"punctuate": True, "interim_results": True},
    )
    
    tts = CartesiaTTSService(
        api_key=CARTESIA_API_KEY,
        voice_id="79a125e8-cd45-4c13-8a67-188112f4dd22",
    )
    
    llm = OpenAILLMService(
        api_key=OPENAI_API_KEY,
        model="gpt-4o-mini",
    )
    
    vad = SileroVADAnalyzer()
    
    pipeline = Pipeline([
        transport.input(),
        stt,
        vad,
        llm,
        tts,
        transport.output(),
        CallAnalyticsProcessor(),
        CallResultProcessor(),
    ])
    
    task = PipelineTask(
        pipeline,
        params=PipelineParams(
            allow_interruptions=True,
            audio_in_sample_rate=16000,
            audio_out_sample_rate=16000,
        )
    )
    
    runner = PipelineRunner()
    await runner.run(task)
    logger.info("🎉 程序结束")

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        logger.info("\n👋 系统已停止")
    except Exception as e:
        logger.error(f"❌ 系统错误: {e}")
        raise
