import asyncio

import structlog
import websockets
from websockets.server import WebSocketServerProtocol

from config.settings import get_settings
from freeswitch.models import FreeSwitchConnectionContext

logger = structlog.get_logger(__name__)


class FreeSwitchAudioServer:
    def __init__(self) -> None:
        self.settings = get_settings()

        self._server: websockets.WebSocketServer | None = None

        self._active_connections: set[WebSocketServerProtocol] = set()

    async def start(self) -> None:
        self._server = await websockets.serve(
            self.handle_connection,
            self.settings.host,
            self.settings.port,
            max_size=None,
            ping_interval=self.settings.websocket_ping_interval,
            ping_timeout=self.settings.websocket_ping_timeout,
        )

    async def stop(self) -> None:
        if self._server is None:
            return

        self._server.close()

        await self._server.wait_closed()

    async def handle_connection(
        self,
        websocket: WebSocketServerProtocol,
    ) -> None:
        remote = "unknown"

        if websocket.remote_address:
            remote = f"{websocket.remote_address[0]}:{websocket.remote_address[1]}"

        context = FreeSwitchConnectionContext.create(remote)

        self._active_connections.add(websocket)

        logger.info(
            "freeswitch_connection_opened",
            connection_id=context.connection_id,
            remote_address=context.remote_address,
        )

        try:
            await self._connection_loop(websocket, context)

        except websockets.ConnectionClosed:
            logger.info(
                "freeswitch_connection_closed",
                connection_id=context.connection_id,
            )

        except Exception:
            logger.exception(
                "freeswitch_connection_error",
                connection_id=context.connection_id,
            )

        finally:
            self._active_connections.discard(websocket)

    async def _connection_loop(
        self,
        websocket: WebSocketServerProtocol,
        context: FreeSwitchConnectionContext,
    ) -> None:
        async for message in websocket:
            if not isinstance(message, bytes):
                logger.warning(
                    "unexpected_non_binary_frame",
                    connection_id=context.connection_id,
                )
                continue

            logger.debug(
                "audio_frame_received",
                connection_id=context.connection_id,
                size=len(message),
            )

            #
            # Next step:
            # route inbound PCM frames into CallSession
            #

            await asyncio.sleep(0)
