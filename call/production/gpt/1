from __future__ import annotations

import asyncio
import contextlib
import time
from uuid import uuid4

import structlog
from websockets.server import WebSocketServerProtocol

from ai.minicpm_client import MiniCPMClient
from ai.protocol import OutboundAudioFrame
from audio.playback_buffer import PlaybackBuffer
from audio.vad import VoiceActivityDetector
from config.settings import get_settings
from infra.metrics import ACTIVE_CALLS
from infra.metrics import AUDIO_IN_BYTES
from infra.metrics import AUDIO_OUT_BYTES
from infra.metrics import INTERRUPT_COUNT
from session.state import CallState

logger = structlog.get_logger(__name__)


class CallSession:
    def __init__(
        self,
        websocket: WebSocketServerProtocol,
    ) -> None:
        self.settings = get_settings()

        self.session_id = str(uuid4())

        self.websocket = websocket

        self.state = CallState.INITIALIZING

        self.created_at = time.monotonic()

        self.inbound_audio_queue: asyncio.Queue[bytes] = asyncio.Queue(
            maxsize=self.settings.inbound_audio_queue_size
        )

        self.outbound_audio_queue: asyncio.Queue[OutboundAudioFrame] = asyncio.Queue(
            maxsize=self.settings.outbound_audio_queue_size
        )

        self.playback_buffer = PlaybackBuffer()

        self.vad = VoiceActivityDetector()

        self.minicpm = MiniCPMClient(
            session_id=self.session_id,
            outbound_audio_queue=self.outbound_audio_queue,
        )

        self.tasks: list[asyncio.Task] = []

        self.current_generation_id = 0

        self.consecutive_speech_frames = 0

    async def start(self) -> None:
        ACTIVE_CALLS.inc()

        logger.info(
            "call_session_starting",
            session_id=self.session_id,
        )

        await self.minicpm.connect()

        self.state = CallState.ACTIVE

        self.tasks.extend(
            [
                asyncio.create_task(
                    self._inbound_audio_loop(),
                    name=f"inbound-audio-{self.session_id}",
                ),
                asyncio.create_task(
                    self._outbound_audio_loop(),
                    name=f"outbound-audio-{self.session_id}",
                ),
            ]
        )

        logger.info(
            "call_session_started",
            session_id=self.session_id,
        )

    async def close(self) -> None:
        self.state = CallState.CLOSING

        logger.info(
            "call_session_closing",
            session_id=self.session_id,
        )

        for task in self.tasks:
            task.cancel()

        for task in self.tasks:
            with contextlib.suppress(asyncio.CancelledError):
                await task

        await self.minicpm.close()

        ACTIVE_CALLS.dec()

        self.state = CallState.CLOSED

        logger.info(
            "call_session_closed",
            session_id=self.session_id,
        )

    async def receive_audio(self, pcm: bytes) -> None:
        AUDIO_IN_BYTES.inc(len(pcm))

        await self.inbound_audio_queue.put(pcm)

    async def _inbound_audio_loop(self) -> None:
        while True:
            pcm = await self.inbound_audio_queue.get()

            speech = self.vad.is_speech(pcm)

            if speech:
                self.consecutive_speech_frames += 1
            else:
                self.consecutive_speech_frames = 0

            required_frames = (
                self.settings.interrupt_speech_ms
                // self.settings.audio_chunk_ms
            )

            if self.consecutive_speech_frames >= required_frames:
                await self._handle_interrupt()

            await self.minicpm.send_audio(pcm)

    async def _outbound_audio_loop(self) -> None:
        while True:
            frame = await self.outbound_audio_queue.get()

            if frame.generation_id != self.minicpm.current_generation_id:
                logger.debug(
                    "dropping_stale_audio",
                    session_id=self.session_id,
                    generation_id=frame.generation_id,
                )

                continue

            AUDIO_OUT_BYTES.inc(len(frame.audio))

            await self.websocket.send(frame.audio)

    async def _handle_interrupt(self) -> None:
        self.consecutive_speech_frames = 0

        INTERRUPT_COUNT.inc()

        logger.info(
            "interrupt_detected",
            session_id=self.session_id,
        )

        generation_id = await self.minicpm.interrupt()

        self.current_generation_id = generation_id

