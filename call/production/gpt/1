            remote_address=remote,
        )

        handler = FreeSwitchConnectionHandler(
            websocket=websocket,
        )

        try:
            await handler.run()

        except websockets.ConnectionClosed:
            logger.info(
                "freeswitch_connection_closed",
                remote_address=remote,
            )

        except Exception:
            logger.exception(
                "freeswitch_connection_error",
                remote_address=remote,
            )

        finally:
            self._active_connections.discard(websocket)
