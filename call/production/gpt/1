    async def put(self, audio: bytes) -> None:
        frame = BufferedAudioFrame(
            audio=audio,
            received_at=time.monotonic(),
        )

        await self.queue.put(frame)

    async def get(self) -> bytes:
        frame = await self.queue.get()

        return frame.audio
