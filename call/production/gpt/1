        self.closed = True

        self.state = CallState.CLOSING

        logger.info(
            "call_session_closing",
            session_id=self.session_id,
        )

        for task in self.tasks:
            task.cancel()

        for task in self.tasks:
            with contextlib.suppress(asyncio.CancelledError):
                await task

        await self.minicpm.close()

        duration = time.monotonic() - self.created_at

        SESSION_DURATION.observe(duration)

        ACTIVE_CALLS.dec()

        self.state = CallState.CLOSED

        logger.info(
            "call_session_closed",
            session_id=self.session_id,
            duration_seconds=round(duration, 2),
        )

