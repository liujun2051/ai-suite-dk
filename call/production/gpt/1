from __future__ import annotations

import audioop

import numpy as np


def pcm16_bytes_to_float32(pcm: bytes) -> np.ndarray:
    audio = np.frombuffer(pcm, dtype=np.int16)

    return audio.astype(np.float32) / 32768.0


def float32_to_pcm16_bytes(audio: np.ndarray) -> bytes:
    clipped = np.clip(audio, -1.0, 1.0)

    int16_audio = (clipped * 32767.0).astype(np.int16)

    return int16_audio.tobytes()


def resample_audio(
    pcm: bytes,
    source_rate: int,
    target_rate: int,
) -> bytes:
    if source_rate == target_rate:
        return pcm

    return audioop.ratecv(
        pcm,
        2,
        1,
        source_rate,
        target_rate,
        None,
    )[0]


def ulaw_to_pcm16(ulaw_data: bytes) -> bytes:
    return audioop.ulaw2lin(ulaw_data, 2)


def pcm16_to_ulaw(pcm_data: bytes) -> bytes:
    return audioop.lin2ulaw(pcm_data, 2)
