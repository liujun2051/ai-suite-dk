from __future__ import annotations

import asyncio

from ai.protocol import OutboundAudioFrame


class PlaybackBuffer:
    """
    Generation-aware playback queue.

    Old generations are discarded after interruption.
    """

    def __init__(
        self,
        maxsize: int = 256,
    ) -> None:
        self.queue: asyncio.Queue[OutboundAudioFrame] = asyncio.Queue(
            maxsize=maxsize
        )

    async def put(
        self,
        frame: OutboundAudioFrame,
    ) -> None:
        await self.queue.put(frame)

    async def get(self) -> OutboundAudioFrame:
        return await self.queue.get()

    def clear_stale(
        self,
        active_generation_id: int,
    ) -> int:
        retained: list[OutboundAudioFrame] = []

        dropped = 0

        while not self.queue.empty():
            frame = self.queue.get_nowait()

            if frame.generation_id == active_generation_id:
                retained.append(frame)
            else:
                dropped += 1

        for frame in retained:
            self.queue.put_nowait(frame)

        return dropped
