from __future__ import annotations


class PCMChunker:
    """
    Ensures stable PCM frame sizing.

    Many realtime APIs behave poorly when:
    - frame sizes vary
    - chunks become too large
    - websocket packet timing drifts

    This normalizes stream chunking.
    """

    def __init__(
        self,
        sample_rate: int,
        chunk_ms: int,
        channels: int = 1,
        bytes_per_sample: int = 2,
    ) -> None:
        self.sample_rate = sample_rate

        self.chunk_ms = chunk_ms

        self.channels = channels

        self.bytes_per_sample = bytes_per_sample

        self.chunk_size = int(
            (
                self.sample_rate
                * self.chunk_ms
                / 1000
            )
            * self.channels
            * self.bytes_per_sample
        )

        self.buffer = bytearray()

    def append(
        self,
        pcm: bytes,
    ) -> list[bytes]:
        self.buffer.extend(pcm)

        chunks: list[bytes] = []

        while len(self.buffer) >= self.chunk_size:
            chunk = bytes(
                self.buffer[: self.chunk_size]
            )

            del self.buffer[: self.chunk_size]

            chunks.append(chunk)

        return chunks

    def flush(self) -> bytes:
        if not self.buffer:
            return b""

        remaining = bytes(self.buffer)

        self.buffer.clear()

        return remaining
