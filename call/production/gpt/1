from functools import lru_cache

from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        case_sensitive=False,
        extra="ignore",
    )

    app_name: str = "minicpm-freeswitch-agent"
    environment: str = "development"
    log_level: str = "INFO"

    host: str = "0.0.0.0"
    port: int = 8765

    metrics_host: str = "0.0.0.0"
    metrics_port: int = 9000

    minicpm_ws_url: str = Field(
        default="wss://api.minicpm.example/realtime"
    )

    minicpm_api_key: str = Field(
        default=""
    )

    audio_sample_rate: int = 16000
    audio_channels: int = 1
    audio_chunk_ms: int = 20

    vad_aggressiveness: int = 2
    vad_frame_ms: int = 20

    interrupt_speech_ms: int = 240

    outbound_audio_queue_size: int = 128
    inbound_audio_queue_size: int = 128

    session_idle_timeout_seconds: int = 300

    enable_metrics: bool = True

    websocket_ping_interval: int = 20
    websocket_ping_timeout: int = 20

    freeswitch_client_timeout_seconds: int = 15

    minicpm_connect_timeout_seconds: int = 10

    max_concurrent_sessions: int = 20


@lru_cache
def get_settings() -> Settings:
    return Settings()
