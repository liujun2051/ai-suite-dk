from __future__ import annotations

from dataclasses import dataclass


@dataclass(slots=True)
class TurnDetectionResult:
    should_interrupt: bool = False

    should_commit: bool = False


class TurnDetector:
    """
    Stateful speech turn detector.

    Separates:
    - interruption logic
    - endpointing logic

    This becomes extremely important once:
    - latency tuning
    - multilingual callers
    - noisy PSTN environments
    - duplex overlap

    enter the system.
    """

    def __init__(
        self,
        interrupt_frames: int,
        silence_frames: int,
    ) -> None:
        self.interrupt_frames = interrupt_frames

        self.silence_frames = silence_frames

        self.speech_counter = 0

        self.silence_counter = 0

        self.user_currently_speaking = False

    def update(
        self,
        is_speech: bool,
        is_silence: bool,
    ) -> TurnDetectionResult:
        result = TurnDetectionResult()

        if is_speech:
            self.speech_counter += 1
            self.silence_counter = 0

        elif is_silence:
            self.silence_counter += 1
            self.speech_counter = 0

        else:
            self.speech_counter = 0

        if (
            self.speech_counter
            >= self.interrupt_frames
        ):
            if not self.user_currently_speaking:
                result.should_interrupt = True

            self.user_currently_speaking = True

        if (
            self.user_currently_speaking
            and self.silence_counter
            >= self.silence_frames
        ):
            result.should_commit = True

            self.user_currently_speaking = False

            self.speech_counter = 0

            self.silence_counter = 0

        return result
