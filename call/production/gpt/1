                await self._handle_interrupt()

            await self.minicpm.send_audio(
                pcm
            )

            await self._maybe_commit_audio()

    async def _maybe_commit_audio(
        self,
    ) -> None:
        if (
            not self.settings
            .minicpm_auto_commit_audio
        ):
            return

        required_silence_frames = (
            self.settings.silence_commit_ms
            // self.settings.audio_chunk_ms
        )

        if (
            self.consecutive_silence_frames
            >= required_silence_frames
        ):
            logger.info(
                "audio_commit_triggered",
                session_id=self.session_id,
            )

            self.consecutive_silence_frames = 0

            await self.minicpm.commit_audio()

    async def _outbound_audio_loop(self) -> None:
        while True:
            frame = (
                await self.outbound_audio_queue.get()
            )

            if (
                frame.generation_id
                != self.minicpm.current_generation_id
            ):
                logger.debug(
                    "dropping_stale_audio",
                    session_id=self.session_id,
                    generation_id=(
                        frame.generation_id
                    ),
                )

                continue

            AUDIO_OUT_BYTES.inc(
                len(frame.audio)
            )

            if (
                self.settings
                .enable_audio_pacing
            ):
                await self.audio_clock.pace(
                    frame.audio
                )

            try:
                await self.websocket.send(
                    frame.audio
                )

            except Exception:
                logger.exception(
                    "outbound_audio_send_failed",
                    session_id=self.session_id,
                )

                raise

    async def _handle_interrupt(
        self,
    ) -> None:
        now = time.monotonic()

        delta = (
            now - self.last_interrupt_at
        )

        if (
            delta > 0
            and (1 / delta)
            > self.settings
            .max_interrupts_per_second
        ):
            return

        self.last_interrupt_at = now

        self.consecutive_speech_frames = 0

        INTERRUPT_COUNT.inc()

        logger.info(
            "interrupt_detected",
            session_id=self.session_id,
        )

        generation_id = (
            await self.minicpm.interrupt()
        )

        self.current_generation_id = (
            generation_id
        )

        dropped = (
            self.playback_buffer
            .clear_stale(
                active_generation_id=(
                    generation_id
                )
            )
        )

        logger.info(
            "playback_buffer_cleared",
            session_id=self.session_id,
            dropped_frames=dropped,
        )

    async def _idle_watchdog_loop(
        self,
    ) -> None:
        while True:
            await asyncio.sleep(5)

            idle_seconds = (
                time.monotonic()
                - self.last_audio_at
            )

            if (
                idle_seconds
                > self.settings
                .session_idle_timeout_seconds
            ):
                logger.info(
                    "session_idle_timeout",
                    session_id=self.session_id,
                    idle_seconds=round(
                        idle_seconds,
                        2,
                    ),
                )

                await self.websocket.close()

                return
