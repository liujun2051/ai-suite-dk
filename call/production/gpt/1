from __future__ import annotations

import asyncio
import base64
import contextlib
import time

import orjson
import structlog
import websockets

from ai.protocol import MiniCPMMessageType
from ai.protocol import OutboundAudioFrame
from ai.reconnect import ExponentialBackoff
from config.settings import get_settings
from infra.metrics import ACTIVE_MINICPM_CONNECTIONS
from infra.metrics import MINICPM_RECONNECTS
from infra.metrics import OUTBOUND_QUEUE_DROPS

logger = structlog.get_logger(__name__)


class MiniCPMClient:
    """
    Production realtime websocket client.

    Handles:
    - duplex audio
    - reconnects
    - heartbeats
    - generation tracking
    - queue protection
    """

    def __init__(
        self,
        session_id: str,
        outbound_audio_queue: asyncio.Queue[OutboundAudioFrame],
    ) -> None:
        self.settings = get_settings()

        self.session_id = session_id

        self.outbound_audio_queue = outbound_audio_queue

        self.websocket: (
            websockets.WebSocketClientProtocol | None
        ) = None

        self.read_task: asyncio.Task | None = None

        self.heartbeat_task: asyncio.Task | None = None

        self.connected = False

        self.closing = False

        self.current_generation_id = 0

        self._write_lock = asyncio.Lock()

        self.last_server_activity = time.monotonic()

        self.reconnect_backoff = ExponentialBackoff()

    async def connect(self) -> None:
        if self.connected:
            return

        logger.info(
            "minicpm_connecting",
            session_id=self.session_id,
        )

        headers = {
            "Authorization": (
                f"Bearer "
                f"{self.settings.minicpm_api_key}"
            ),
        }

        self.websocket = await websockets.connect(
            self.settings.minicpm_ws_url,
            extra_headers=headers,
            max_size=None,
            ping_interval=(
                self.settings.websocket_ping_interval
            ),
            ping_timeout=(
                self.settings.websocket_ping_timeout
            ),
            open_timeout=(
                self.settings.minicpm_connect_timeout_seconds
            ),
        )

        self.connected = True

        ACTIVE_MINICPM_CONNECTIONS.inc()

        self.read_task = asyncio.create_task(
            self._reader_loop(),
            name=f"minicpm-reader-{self.session_id}",
        )

        self.heartbeat_task = asyncio.create_task(
            self._heartbeat_loop(),
            name=f"minicpm-heartbeat-{self.session_id}",
        )

        logger.info(
            "minicpm_connected",
            session_id=self.session_id,
        )

    async def close(self) -> None:
        self.closing = True

        self.connected = False

        tasks = [
            self.read_task,
            self.heartbeat_task,
        ]

        for task in tasks:
            if task:
                task.cancel()

        for task in tasks:
            if task:
                with contextlib.suppress(
                    asyncio.CancelledError
                ):
                    await task

        if self.websocket:
            await self.websocket.close()

        ACTIVE_MINICPM_CONNECTIONS.dec()

        logger.info(
            "minicpm_closed",
            session_id=self.session_id,
        )

    async def send_audio(
        self,
        pcm: bytes,
    ) -> None:
        await self._ensure_connection()

        if not self.websocket:
            return

        payload = {
            "type": (
                MiniCPMMessageType
                .INPUT_AUDIO_BUFFER_APPEND
                .value
            ),
            "audio": (
                base64.b64encode(pcm).decode()
            ),
        }

        try:
            async with self._write_lock:
                await self.websocket.send(
                    orjson.dumps(payload).decode()
                )

        except Exception:
            logger.exception(
                "minicpm_send_audio_failed",
                session_id=self.session_id,
            )

            self.connected = False

            raise

    async def interrupt(self) -> int:
        await self._ensure_connection()

        if not self.websocket:
            return self.current_generation_id

        self.current_generation_id += 1

        generation_id = (
            self.current_generation_id
        )

        payload = {
            "type": (
                MiniCPMMessageType.INTERRUPT.value
            ),
        }

        logger.info(
            "sending_interrupt",
            session_id=self.session_id,
            generation_id=generation_id,
        )

        try:
            async with self._write_lock:
                await self.websocket.send(
                    orjson.dumps(payload).decode()
                )

        except Exception:
            logger.exception(
                "interrupt_send_failed",
                session_id=self.session_id,
            )

            self.connected = False

        return generation_id

    async def _ensure_connection(self) -> None:
        if self.connected:
            return

        if self.closing:
            return

        while not self.connected:
            try:
                MINICPM_RECONNECTS.inc()

                logger.warning(
                    "minicpm_reconnecting",
                    session_id=self.session_id,
                )

                await self.connect()

                self.reconnect_backoff.reset()

                logger.info(
                    "minicpm_reconnected",
                    session_id=self.session_id,
                )

                return

            except Exception:
                logger.exception(
                    "minicpm_reconnect_failed",
                    session_id=self.session_id,
                )

                await self.reconnect_backoff.sleep()

    async def _reader_loop(self) -> None:
        assert self.websocket is not None

        try:
            async for raw_message in self.websocket:
                self.last_server_activity = (
                    time.monotonic()
                )

                try:
                    if isinstance(
                        raw_message,
                        bytes,
                    ):
                        continue

                    message = orjson.loads(
                        raw_message
                    )

                    await self._handle_message(
                        message
                    )

                except Exception:
                    logger.exception(
                        "minicpm_reader_error",
                        session_id=self.session_id,
                    )

        except Exception:
            logger.exception(
                "minicpm_reader_disconnected",
                session_id=self.session_id,
            )

            self.connected = False

    async def _handle_message(
        self,
        message: dict,
    ) -> None:
        message_type = message.get("type")

        if (
            message_type
            == MiniCPMMessageType
            .RESPONSE_STARTED
            .value
        ):
            self.current_generation_id += 1

            logger.info(
                "response_started",
                session_id=self.session_id,
                generation_id=(
                    self.current_generation_id
                ),
            )

            return

        if (
            message_type
            == MiniCPMMessageType
            .RESPONSE_AUDIO_DELTA
            .value
        ):
            audio_b64 = message.get("audio")

            if not audio_b64:
                return

            pcm = base64.b64decode(
                audio_b64
            )

            frame = OutboundAudioFrame(
                generation_id=(
                    self.current_generation_id
                ),
                audio=pcm,
            )

            try:
                self.outbound_audio_queue.put_nowait(
                    frame
                )

            except asyncio.QueueFull:
                OUTBOUND_QUEUE_DROPS.inc()

                logger.warning(
                    "outbound_audio_queue_full",
                    session_id=self.session_id,
                )

            return

        if (
            message_type
            == MiniCPMMessageType
            .RESPONSE_DONE
            .value
        ):
            logger.info(
                "response_done",
                session_id=self.session_id,
                generation_id=(
                    self.current_generation_id
                ),
            )

            return

        if (
            message_type
            == MiniCPMMessageType.ERROR.value
        ):
            logger.error(
                "minicpm_error",
                session_id=self.session_id,
                payload=message,
            )

    async def _heartbeat_loop(self) -> None:
        while True:
            await asyncio.sleep(10)

            idle = (
                time.monotonic()
                - self.last_server_activity
            )

            if idle > 60:
                logger.warning(
                    "minicpm_server_idle",
                    session_id=self.session_id,
                    idle_seconds=round(idle, 2),
                )

                self.connected = False
