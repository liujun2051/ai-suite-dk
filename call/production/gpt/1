class JitterBuffer:
    def __init__(
        self,
        target_delay_ms: int = 60,
        max_frames: int = 64,
    ) -> None:
        self.target_delay_ms = target_delay_ms

        self.queue: asyncio.Queue[BufferedAudioFrame] = asyncio.Queue(
