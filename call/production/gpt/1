from __future__ import annotations

import asyncio
import time


class AudioClock:
    """
    Maintains realtime pacing for outbound audio.

    Without pacing:
    - audio bursts
    - websocket flooding
    - playback distortion
    - FreeSWITCH jitter

    This is critical for production stability.
    """

    def __init__(
        self,
        sample_rate: int,
        channels: int,
        bytes_per_sample: int = 2,
    ) -> None:
        self.sample_rate = sample_rate
        self.channels = channels
        self.bytes_per_sample = bytes_per_sample

        self.stream_time_seconds = 0.0

        self.started_at = time.monotonic()

    async def pace(self, pcm: bytes) -> None:
        frame_duration = (
            len(pcm)
            / (
                self.sample_rate
                * self.channels
                * self.bytes_per_sample
            )
        )

        self.stream_time_seconds += frame_duration

        elapsed = time.monotonic() - self.started_at

        delay = self.stream_time_seconds - elapsed

        if delay > 0:
            await asyncio.sleep(delay)
