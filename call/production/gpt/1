from collections import deque


class AudioRingBuffer:
    """
    Small rolling audio history buffer.

    Useful for:
    - interruption recovery
    - context replay
    - future wake-word support
    """

    def __init__(
        self,
        max_frames: int = 50,
    ) -> None:
        self.frames: deque[bytes] = deque(
            maxlen=max_frames
        )

    def append(
        self,
        pcm: bytes,
    ) -> None:
        self.frames.append(pcm)

    def clear(self) -> None:
        self.frames.clear()

    def dump(self) -> bytes:
        return b"".join(self.frames)
