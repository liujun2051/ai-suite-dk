from __future__ import annotations

from config.settings import get_settings


class AudioFrameValidator:
    """
    Guards against malformed audio frames.

    Protects:
    - memory abuse
    - websocket flooding
    - broken upstream payloads
    """

    def __init__(self) -> None:
        self.settings = get_settings()

    def validate(
        self,
        pcm: bytes,
    ) -> bool:
        if not pcm:
            return False

        if (
            len(pcm)
            > self.settings
            .inbound_audio_max_frame_size_bytes
        ):
            return False

        if len(pcm) % 2 != 0:
            return False

        return True
