# ============================================================
# VoiceBot environment variables
# Copy to .env and fill in your values
# DO NOT commit .env to version control
# ============================================================

# ---- Required ----
MINICPM_API_KEY=your_minicpm_api_key_here

# ---- FreeSWITCH ESL ----
VOICEBOT__ESL__HOST=127.0.0.1
VOICEBOT__ESL__PORT=8021
VOICEBOT__ESL__PASSWORD=ClueCon

# ---- Application ----
VOICEBOT__ENVIRONMENT=production
VOICEBOT__DEBUG=false

# ---- Logging ----
VOICEBOT__LOG__LEVEL=INFO
VOICEBOT__LOG__FILE_ENABLED=true
VOICEBOT__LOG__FILE_PATH=logs/voicebot.log
VOICEBOT__LOG__JSON_ENABLED=false

# ---- API security (optional) ----
VOICEBOT__API__AUTH_ENABLED=false
VOICEBOT__API__AUTH_TOKEN=

# ---- Prometheus ----
VOICEBOT__METRICS__PROMETHEUS_ENABLED=true
VOICEBOT__METRICS__PROMETHEUS_PORT=9090

# ---- Docker Compose extras ----
ESL_PASSWORD=ClueCon
FREESWITCH_DOMAIN=localhost
GRAFANA_PASSWORD=admin
API_AUTH_ENABLED=false
API_AUTH_TOKEN=
