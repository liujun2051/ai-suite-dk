### 安装脚本

```bash
#!/bin/bash
# install.sh - J1800 一键安装部署

set -e

echo "=== VoiceBot 安装 (J1800 优化版) ==="

# 1. 系统更新
apt update && apt upgrade -y

# 2. 依赖
apt install -y \
    python3.11 \
    python3.11-venv \
    python3-pip \
    curl \
    htop \
    iotop

# 3. Python 环境
python3.11 -m venv /opt/voicebot/venv
source /opt/voicebot/venv/bin/activate

# 4. 安装 Python 包
pip install --upgrade pip
pip install \
    websockets \
    aiohttp \
    uvloop \
    webrtcvad \
    numpy \
    prometheus-client \
    psutil \
    python-dotenv \
    PyYAML

# 注意：J1800 不安装 scipy
# audioop 已经够用，scipy 在 J1800 上编译慢且收益小
echo "跳过 scipy（J1800 上 audioop 已够用）"

# 5. 关闭不必要服务
systemctl disable --now \
    snapd \
    cups \
    bluetooth \
    avahi-daemon \
    2>/dev/null || true

# 6. 系统参数
cat > /etc/sysctl.d/99-voicebot.conf << 'EOF'
net.core.rmem_max = 4194304
net.core.wmem_max = 4194304
net.ipv4.tcp_nodelay = 1
fs.file-max = 32768
EOF
sysctl -p /etc/sysctl.d/99-voicebot.conf

# 7. 文件描述符
cat >> /etc/security/limits.conf << 'EOF'
voicebot soft nofile 16384
voicebot hard nofile 16384
freeswitch soft nofile 16384
freeswitch hard nofile 16384
EOF

echo "=== 安装完成 ==="
echo "下一步："
echo "  1. cp .env.example .env && nano .env"
echo "  2. systemctl start voicebot"
```

