import asyncio
import logging
import time

from app.audio import *
from app.ai_client import AIClient
from app.config import *
from app.metrics import *

logger = logging.getLogger(__name__)


class CallSession:

    def __init__(
        self,
        call_id,
        websocket,
        loop
    ):

        self.call_id = call_id

        self.ws = websocket

        self.loop = loop

        self.ai = None

        self.active = True

        self.is_ai_speaking = False

        self.last_activity = time.time()

        self.interrupt_lock = asyncio.Lock()

        self.tx_queue = asyncio.Queue(
            maxsize=100
        )

    # --------------------------------------------

    async def start(self):

        self.ai = AIClient(self)

        await self.ai.connect()

        asyncio.create_task(
            self.tx_worker()
        )

        asyncio.create_task(
            self.watchdog()
        )

        logger.info(
            f"[{self.call_id}] started"
        )

    # --------------------------------------------

    async def watchdog(self):

        while self.active:

            await asyncio.sleep(5)

            now = time.time()

            if (
                now - self.last_activity
                > SESSION_IDLE_TIMEOUT
            ):

                logger.warning(
                    "[%s] idle timeout",
                    self.call_id
                )

                await self.close()

                return

            if (
                now - self.ai.last_response_time
                > AI_RESPONSE_TIMEOUT
                and self.is_ai_speaking
            ):

                logger.warning(
                    "[%s] ai timeout",
                    self.call_id
                )

                self.is_ai_speaking = False

    # --------------------------------------------

    async def on_rtp_audio(
        self,
        audio_bytes
    ):

        self.last_activity = time.time()

        AUDIO_RX_BYTES.inc(
            len(audio_bytes)
        )

        pcm8k = bytes_to_pcm16(
            audio_bytes
        )

        pcm16k = resample(
            pcm8k,
            PLAYBACK_SAMPLE_RATE,
            AI_SAMPLE_RATE
        )

        await self.ai.send_audio(
            pcm16_to_bytes(
                pcm16k
            )
        )

    # --------------------------------------------

    def on_ai_audio(
        self,
        audio_16k
    ):

        if not self.active:
            return

        self.is_ai_speaking = True

        pcm16k = bytes_to_pcm16(
            audio_16k
        )

        pcm8k = resample(
            pcm16k,
            AI_SAMPLE_RATE,
            PLAYBACK_SAMPLE_RATE
        )

        out = pcm16_to_bytes(
            pcm8k
        )

        AUDIO_TX_BYTES.inc(
            len(out)
        )

        try:

            self.tx_queue.put_nowait(out)

        except asyncio.QueueFull:

            logger.warning(
                "[%s] tx overflow",
                self.call_id
            )

            try:
                self.tx_queue.get_nowait()
            except:
                pass

    # --------------------------------------------

    async def tx_worker(self):

        while self.active:

            try:

                audio = await self.tx_queue.get()

                await self.ws.send_bytes(
                    audio
                )

            except Exception:

                logger.exception(
                    "tx worker"
                )

                break

    # --------------------------------------------

    def on_ai_done(self):

        self.is_ai_speaking = False

    # --------------------------------------------

    def on_user_speech(self):

        if self.is_ai_speaking:

            asyncio.run_coroutine_threadsafe(
                self.barge_in(),
                self.loop
            )

    # --------------------------------------------

    async def barge_in(self):

        async with self.interrupt_lock:

            BARGE_IN_TOTAL.inc()

            logger.info(
                "[%s] barge-in",
                self.call_id
            )

            await self.ai.interrupt()

            self.is_ai_speaking = False

            while not self.tx_queue.empty():

                try:
                    self.tx_queue.get_nowait()
                except:
                    break

    # --------------------------------------------

    async def close(self):

        if not self.active:
            return

        self.active = False

        try:

            await self.ai.close()

        except:
            pass

        logger.info(
            "[%s] closed",
            self.call_id
        )
