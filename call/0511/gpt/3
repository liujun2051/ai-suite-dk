import asyncio
import base64
import json
import logging
import time

import websockets

from app.config import *
from app.metrics import *

logger = logging.getLogger(__name__)


class AIClient:

    def __init__(self, session):

        self.session = session

        self.ws = None

        self.connected = False

        self.pending_ms = 0

        self.last_response_time = time.time()

    # --------------------------------------------

    async def connect(self):

        backoff = 1

        while True:

            try:

                headers = {
                    "Authorization":
                        f"Bearer {AI_API_KEY}",
                    "OpenAI-Beta":
                        "realtime=v1"
                }

                self.ws = await websockets.connect(
                    AI_WS_URL,
                    additional_headers=headers,
                    compression=None,
                    ping_interval=20,
                    ping_timeout=10,
                )

                self.connected = True

                asyncio.create_task(
                    self.recv_loop()
                )

                await self.initialize()

                logger.info(
                    "AI connected"
                )

                return

            except Exception:

                logger.exception(
                    "AI connect failed"
                )

                AI_RECONNECTS.inc()

                await asyncio.sleep(
                    backoff
                )

                backoff = min(
                    backoff * 2,
                    30
                )

    # --------------------------------------------

    async def initialize(self):

        while True:

            msg = await self.ws.recv()

            data = json.loads(msg)

            if data.get(
                "type"
            ) == "session.created":
                break

        await self.ws.send(json.dumps({
            "type": "session.update",
            "session": {
                "voice": "alloy",
                "instructions":
                    "你是专业中文电话客服助手，"
                    "回答简洁自然。",
                "turn_detection": {
                    "type": "server_vad"
                },
                "input_audio_format":
                    "pcm16",
                "output_audio_format":
                    "pcm16",
            }
        }))

    # --------------------------------------------

    async def send_audio(self, pcm16):

        if not self.connected:
            return

        b64 = base64.b64encode(
            pcm16
        ).decode()

        await self.ws.send(json.dumps({
            "type":
                "input_audio_buffer.append",
            "audio":
                b64
        }))

        self.pending_ms += FRAME_MS

        if self.pending_ms >= 400:

            await self.ws.send(json.dumps({
                "type":
                    "input_audio_buffer.commit"
            }))

            self.pending_ms = 0

    # --------------------------------------------

    async def send_text(self, text):

        await self.ws.send(json.dumps({
            "type":
                "conversation.item.create",
            "item": {
                "type":
                    "message",
                "role":
                    "user",
                "content": [
                    {
                        "type":
                            "input_text",
                        "text":
                            text
                    }
                ]
            }
        }))

        await self.ws.send(json.dumps({
            "type":
                "response.create"
        }))

    # --------------------------------------------

    async def interrupt(self):

        if not self.connected:
            return

        await self.ws.send(json.dumps({
            "type":
                "response.cancel"
        }))

        await self.ws.send(json.dumps({
            "type":
                "input_audio_buffer.clear"
        }))

    # --------------------------------------------

    async def recv_loop(self):

        try:

            async for msg in self.ws:

                data = json.loads(msg)

                t = data.get("type", "")

                if t == (
                    "response.output_audio.delta"
                ):

                    self.last_response_time = (
                        time.time()
                    )

                    audio = base64.b64decode(
                        data["delta"]
                    )

                    self.session.on_ai_audio(
                        audio
                    )

                elif t == (
                    "response.output_audio.done"
                ):

                    self.session.on_ai_done()

                elif t == (
                    "input_audio_buffer."
                    "speech_started"
                ):

                    self.session.on_user_speech()

        except Exception:

            logger.exception(
                "AI recv loop"
            )

            self.connected = False

    # --------------------------------------------

    async def close(self):

        self.connected = False

        if self.ws:
            await self.ws.close()
