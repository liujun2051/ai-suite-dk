import numpy as np


def bytes_to_pcm16(data):

    return np.frombuffer(
        data,
        dtype=np.int16
    )


def pcm16_to_bytes(arr):

    return arr.astype(
        np.int16
    ).tobytes()


def resample(audio, src_rate, dst_rate):

    if src_rate == dst_rate:
        return audio

    ratio = dst_rate / src_rate

    old_len = len(audio)

    new_len = int(old_len * ratio)

    old_idx = np.arange(old_len)

    new_idx = np.linspace(
        0,
        old_len - 1,
        new_len
    )

    return np.interp(
        new_idx,
        old_idx,
        audio
    ).astype(np.int16)
