```python
import asyncio
import base64
import logging
import threading
import time

from app.ai_client import AIClient
from app.audio import (
    bytes_to_pcm16,
    pcm16_to_bytes,
    resample,
)

logger = logging.getLogger(__name__)


class CallSession:

    def __init__(
        self,
        uuid_,
        websocket,
        loop
    ):

        self.uuid = uuid_

        self.ws = websocket

        self.loop = loop

        self.ai = None

        self.active = True

        self.is_ai_speaking = False

        self.play_lock = threading.Lock()

    # ------------------------------------------------

    async def start(self):

        self.ai = AIClient(self)

        await self.ai.connect()

        logger.info(
            "[%s] session started",
            self.uuid
        )

    # ------------------------------------------------

    async def on_rtp_audio(self, audio_bytes):

        if not self.active:
            return

        pcm16 = bytes_to_pcm16(
            audio_bytes
        )

        pcm16_16k = resample(
            pcm16,
            8000,
            16000
        )

        await self.ai.send_audio(
            pcm16_to_bytes(
                pcm16_16k
            )
        )

    # ------------------------------------------------

    def on_ai_audio(self, pcm16_16k):

        if not self.active:
            return

        self.is_ai_speaking = True

        pcm16 = bytes_to_pcm16(
            pcm16_16k
        )

        pcm8k = resample(
            pcm16,
            16000,
            8000
        )

        out = pcm16_to_bytes(
            pcm8k
        )

        asyncio.run_coroutine_threadsafe(
            self.send_audio_to_fs(out),
            self.loop
        )

    # ------------------------------------------------

    async def send_audio_to_fs(self, pcm16):

        if not self.active:
            return

        try:

            await self.ws.send_bytes(
                pcm16
            )

        except Exception:
            logger.exception(
                "send audio to FS"
            )

    # ------------------------------------------------

    def on_ai_done(self):

        self.is_ai_speaking = False

    # ------------------------------------------------

    def on_user_speech(self):

        if self.is_ai_speaking:
            self.barge_in()

    # ------------------------------------------------

    def barge_in(self):

        logger.info(
            "[%s] barge-in",
            self.uuid
        )

        asyncio.run_coroutine_threadsafe(
            self.ai.interrupt(),
            self.loop
        )

        self.is_ai_speaking = False

    # ------------------------------------------------

    async def close(self):

        self.active = False

        if self.ai:
            await self.ai.close()
```

