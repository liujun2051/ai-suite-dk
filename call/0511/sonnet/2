### 8. ESL 事件循环线程异常后无重连机制

```python
# esl.py 的 _event_loop 退出后，整个网关就聋了：
# 不再收到任何 CHANNEL_ANSWER / CHANNEL_HANGUP 事件
# 正在通话的 session 不受影响，但新来的电话全部无响应

# 最小可用的重连：
def _event_loop(self):
    while self._running:
        try:
            headers = self._read_headers()
            # ... 正常处理
        except ConnectionError:
            logger.error("ESL disconnected, reconnecting in 5s...")
            self._connected = False
            time.sleep(5)
            if self._reconnect():
                logger.info("ESL reconnected")
            # 重连后需要重新 subscribe

def _reconnect(self) -> bool:
    try:
        self._buf = b""
        self._sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self._sock.settimeout(10)
        self._sock.connect((self.host, self.port))
        self._sock.settimeout(None)
        # 重新握手
        headers = self._read_headers()
        self._raw_send(f"auth {self.password}\n\n")
        headers = self._read_headers()
        self._connected = True
        # 重新订阅（需要外部传入订阅列表，或缓存）
        return True
    except Exception as e:
        logger.error(f"ESL reconnect failed: {e}")
        return False
```

### 9. `/tmp` 目录 PCMA 文件积累

```bash
# FIFO 模式下，如果进程异常退出，临时文件不会清理
# 长时间运行后 /tmp 会被撑满

# 建议加一个启动时清理：
def main():
    # 清理上次异常退出留下的临时文件
    import glob
    for f in glob.glob("/tmp/minicpm_*.pcma"):
        os.remove(f)
    for d in glob.glob("/tmp/ai_*_*/"):
        shutil.rmtree(d, ignore_errors=True)
```

