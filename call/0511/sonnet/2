## 🔴 必须修复（会导致崩溃/不可用）

### 1. `ai_client.py` — `_make_socket` 与 `websockets.connect` 冲突

```python
# 现在的代码：
self._ws = await websockets.connect(
    config.MINICPM_WS_URL,
    extra_headers=extra_headers,
    sock=await self._make_socket(),   # ❌ 问题在这里
)

# _make_socket 里手动 connect 了 TCP，
# 但 websockets.connect 拿到 sock 参数后会假设 sock 已连接，
# 同时它自己还会再做一次 TLS/WS 握手。
# 对于 ws:// 没有 TLS 时勉强能工作，
# 对于 wss:// 会直接崩溃，因为 TLS 上下文没有正确传递。
```

```python
# 正确做法：不要自己建 socket，让 websockets 建连后设置选项
# websockets >= 12.0 支持 open_timeout 和 additional_headers

async def connect(self) -> bool:
    extra_headers = {}
    if self.mode == "cloud":
        extra_headers["Authorization"] = f"Bearer {config.CLOUD_API_KEY}"
    try:
        self._ws = await asyncio.wait_for(
            websockets.connect(
                config.MINICPM_WS_URL,
                extra_headers=extra_headers,
                ping_interval=20,
                ping_timeout=10,
                max_size=16 * 1024 * 1024,
                # ✅ 通过 create_connection 参数设置 TCP_NODELAY
                create_connection=_make_nodelay_connection,
            ),
            timeout=self._CONNECT_TIMEOUT,
        )
        ...

# 模块级别的工厂函数（不是 _make_socket 那种方式）
async def _make_nodelay_connection(uri, **kwargs):
    """创建禁用 Nagle 算法的 WebSocket 连接。"""
    import socket as _socket
    ws = await websockets.connect(uri, **kwargs)
    # 连接建立后设置 socket 选项
    transport = ws.transport
    if transport:
        sock = transport.get_extra_info("socket")
        if sock:
            sock.setsockopt(_socket.IPPROTO_TCP, _socket.TCP_NODELAY, 1)
    return ws

# 实际上最简单可靠的做法：
# websockets 内部已经针对延迟做了优化，TCP_NODELAY 影响有限。
# 直接去掉 _make_socket，用标准 websockets.connect 即可。
```

