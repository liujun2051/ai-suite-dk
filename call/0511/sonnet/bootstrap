# ══════════════════════════════════════════════════════════════════════
#  自检：验证所有 .py 文件内容是合法的 Python 语法
# ══════════════════════════════════════════════════════════════════════

def self_check():
    errors = []
    for filename, content in FILES.items():
        if not filename.endswith(".py"):
            continue
        try:
            ast.parse(content)
        except SyntaxError as e:
            errors.append(f"  ❌  {filename}: {e}")
    if errors:
        print("\n语法检查失败：")
        for e in errors:
            print(e)
        print("\n请报告此错误。")
        sys.exit(1)
    print(f"  ✅  语法检查通过（{sum(1 for f in FILES if f.endswith('.py'))} 个 Python 文件）")


# ══════════════════════════════════════════════════════════════════════
#  脚手架执行
# ══════════════════════════════════════════════════════════════════════

def main():
    print(f"\n🚀  MiniCPM-o Gateway v3.0 — 项目脚手架")
    print(f"    目标目录：{os.path.abspath(ROOT)}/\n")

    print("  正在检查语法...")
    self_check()
    print()

    # 创建子目录
    for filename in FILES:
        d = os.path.dirname(filename)
        if d:
            os.makedirs(os.path.join(ROOT, d), exist_ok=True)
    os.makedirs(ROOT, exist_ok=True)

    # 写入文件
    created = []
    for filename, content in FILES.items():
        path = os.path.join(ROOT, filename)
        with open(path, "w", encoding="utf-8") as f:
            f.write(content)
        created.append((path, os.path.getsize(path)))

    for path, size in created:
        print(f"  ✅  {path:<60}  {size:>6} bytes")

    print(f"""
{'─' * 62}
下一步：

  cd {ROOT}
  python -m venv .venv
  source .venv/bin/activate          # Windows: .venv\\Scripts\\activate
  pip install -r requirements.txt
  # Python 3.13+：pip install audioop-lts
  python -c "from audio_utils import log_audio_backend; log_audio_backend()"
  vim config.py
  python main.py
{'─' * 62}
""")


if __name__ == "__main__":
    main()
```

**核心改进：**

1. `esl.py` 里所有 `\n`（字节 `b"\n"`、f-string 里的 `\n\n`）在 bootstrap 字符串中写成 `\\n`，写入磁盘后恢复为正确的单个反斜杠加 n
2. 增加 `self_check()` 函数，写入前用 `ast.parse()` 验证每个 `.py` 文件语法，一旦有问题立即报错而不是生成坏文件
