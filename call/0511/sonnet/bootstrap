import logging

logger = logging.getLogger("Metrics")

try:
    from prometheus_client import (
        Counter, Gauge, Histogram, Info,
        start_http_server as _start_http,
    )
    _AVAILABLE = True
except ImportError:
    _AVAILABLE = False
    logger.warning("prometheus_client not installed. pip install prometheus-client")

_NS = "minicpm"


class _Noop:
    def inc(self, *a, **kw):     pass
    def dec(self, *a, **kw):     pass
    def set(self, *a, **kw):     pass
    def observe(self, *a, **kw): pass
    def info(self, *a, **kw):    pass
    def labels(self, *a, **kw):  return self


class GatewayMetrics:

    def __init__(self):
        if not _AVAILABLE:
            self._noop()
            return
        self.active_calls        = Gauge("active_calls", "活跃通话数", namespace=_NS)
        self.calls_total         = Counter("calls_total", "通话总数", ["direction", "result"], namespace=_NS)
        self.call_duration       = Histogram("call_duration_seconds", "通话时长", buckets=[10,30,60,120,300,600,1800], namespace=_NS)
        self.ai_connect_latency  = Histogram("ai_connect_latency_seconds", "AI首帧延迟", buckets=[0.05,0.1,0.2,0.3,0.5,0.8,1.0,2.0,5.0], namespace=_NS)
        self.ai_errors_total     = Counter("ai_errors_total", "AI错误", ["reason"], namespace=_NS)
        self.audio_frames_in     = Counter("audio_frames_in_total", "收到音频帧", namespace=_NS)
        self.audio_frames_out    = Counter("audio_frames_out_total", "发出音频帧", namespace=_NS)
        self.audio_drop_total    = Counter("audio_drop_total", "丢弃音频帧", ["direction"], namespace=_NS)
        self.barge_in_total      = Counter("barge_in_total", "打断次数", namespace=_NS)
        self.transcripts_total   = Counter("transcripts_total", "识别次数", namespace=_NS)
        self.esl_connected       = Gauge("esl_connected", "ESL连接状态", namespace=_NS)
        self.esl_reconnects_total = Counter("esl_reconnects_total", "ESL重连次数", namespace=_NS)
        self.build_info          = Info("build", "版本信息", namespace=_NS)
        self.build_info.info({"version": "3.0", "audio_mode": "mod_audio_stream+fifo"})
        logger.info("Prometheus metrics initialized")

    def _noop(self):
        n = _Noop()
        for attr in ("active_calls","calls_total","call_duration","ai_connect_latency",
                     "ai_errors_total","audio_frames_in","audio_frames_out",
                     "audio_drop_total","barge_in_total","transcripts_total",
                     "esl_connected","esl_reconnects_total","build_info"):
            setattr(self, attr, n)

    def start_http_server(self, port: int = 9090):
        if not _AVAILABLE:
            return
        try:
            _start_http(port)
            logger.info(f"Prometheus -> http://0.0.0.0:{port}/metrics")
        except OSError as e:
            logger.error(f"Metrics server failed :{port}: {e}")
