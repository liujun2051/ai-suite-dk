FILES["audio_utils.py"] = """\"\"\"
audio_utils.py  —  G.711a 编解码 + 重采样

依赖优先级：
  G.711a : audioop（内置）-> audioop-lts（3.13+）-> pyg711
  重采样  : soxr -> scipy -> 线性插值（最差，仅测试）
\"\"\"

import logging
import sys

import numpy as np

logger = logging.getLogger("AudioUtils")


def _load_alaw_codec():
    try:
        import audioop as _a
        def _d(data): return _a.alaw2lin(data, 2)
        def _e(data): return _a.lin2alaw(data, 2)
        logger.debug("G.711a: audioop (built-in)")
        return _d, _e
    except ImportError:
        pass

    try:
        import audioop_lts as _a
        def _d(data): return _a.alaw2lin(data, 2)
        def _e(data): return _a.lin2alaw(data, 2)
        logger.debug("G.711a: audioop-lts")
        return _d, _e
    except ImportError:
        pass

    try:
        import g711
        def _d(data):
            return g711.decode_alaw(
                np.frombuffer(data, dtype=np.uint8)
            ).astype(np.int16).tobytes()
        def _e(data):
            return g711.encode_alaw(
                np.frombuffer(data, dtype=np.int16)
            ).tobytes()
        logger.debug("G.711a: pyg711")
        return _d, _e
    except ImportError:
        pass

    logger.warning(
        "No G.711a library. Using pure-Python fallback. "
        "Install: pip install audioop-lts"
    )
    return _alaw2lin_fallback, _lin2alaw_fallback


def _build_alaw_table():
    table = np.zeros(256, dtype=np.int16)
    for i in range(256):
        a   = i ^ 0x55
        seg = (a & 0x70) >> 4
        val = a & 0x0F
        val = (val << 1) | 1 if seg == 0 else (val | 0x10) << seg
        table[i] = -val if (a & 0x80) == 0 else val
    return table


_ALAW_TABLE = _build_alaw_table()


def _alaw2lin_fallback(data: bytes) -> bytes:
    return np.array([_ALAW_TABLE[b] for b in data], dtype=np.int16).tobytes()


def _encode_alaw_sample(s: int) -> int:
    sign = 0 if s < 0 else 0x80
    s    = min(abs(s), 32767)
    if s < 256:
        enc, seg = s >> 4, 0
    else:
        for seg in range(1, 8):
            if s < (256 << seg):
                break
        enc = (s >> (seg + 3)) & 0x0F
    return (sign | (seg << 4) | enc) ^ 0x55


def _lin2alaw_fallback(data: bytes) -> bytes:
    samples = np.frombuffer(data, dtype=np.int16)
    return np.array(
        [_encode_alaw_sample(int(s)) for s in samples], dtype=np.uint8
    ).tobytes()


_dec, _enc = _load_alaw_codec()


def _load_resample():
    try:
        import soxr
        def _r(data, src, dst):
            if src == dst: return data
            return np.clip(
                soxr.resample(data.astype(np.float32), src, dst, quality="HQ"),
                -32768, 32767
            ).astype(np.int16)
        logger.debug("Resampler: soxr")
        return _r
    except ImportError:
        pass

    try:
        from scipy import signal as _sig
        from math import gcd
        def _r(data, src, dst):
            if src == dst: return data
            g = gcd(src, dst)
            return np.clip(
                _sig.resample_poly(data.astype(np.float64), dst//g, src//g),
                -32768, 32767
            ).astype(np.int16)
        logger.debug("Resampler: scipy")
        return _r
    except ImportError:
        pass

    logger.warning("Resampler: linear interpolation (low quality). Install soxr.")

    def _r(data, src, dst):
        if src == dst: return data
        n = max(1, int(len(data) * dst / src))
        return np.clip(
            np.interp(np.linspace(0, len(data)-1, n), np.arange(len(data)), data),
            -32768, 32767
        ).astype(np.int16)
    return _r


RESAMPLE_FUNC = _load_resample()


def pcma_to_pcm(pcma_bytes: bytes) -> np.ndarray:
    \"\"\"G.711a -> PCM16LE ndarray\"\"\"
    return np.frombuffer(_dec(pcma_bytes), dtype=np.int16).copy()


def pcm_to_pcma(pcm: np.ndarray) -> bytes:
    \"\"\"PCM16LE ndarray -> G.711a bytes\"\"\"
    return _enc(pcm.astype(np.int16).tobytes())


def log_audio_backend():
    v = sys.version_info
    logger.info(f"Audio backend ready | Python {v.major}.{v.minor}.{v.micro}")
"""

FILES["audio.py"] = """\"\"\"
audio.py  —  音频格式转换与帧缓冲 v3.0
\"\"\"

import logging
from typing import List

import numpy as np

from audio_utils import pcma_to_pcm, pcm_to_pcma, RESAMPLE_FUNC

logger = logging.getLogger("Audio")

FS_RATE      = 8_000
AI_RATE      = 16_000
FRAME_MS     = 20
FRAME_PCMA   = FS_RATE  * FRAME_MS // 1000      # 160 bytes
FRAME_PCM16K = AI_RATE  * FRAME_MS // 1000 * 2  # 640 bytes


class AudioConverter:
    \"\"\"FreeSWITCH <-> AI 音频格式转换。无状态，线程安全。\"\"\"

    @staticmethod
    def fs_to_ai(pcma_bytes: bytes) -> bytes:
        \"\"\"G.711a 8kHz -> PCM16LE 16kHz\"\"\"
        if not pcma_bytes:
            return b""
        return RESAMPLE_FUNC(
            pcma_to_pcm(pcma_bytes), FS_RATE, AI_RATE
        ).astype(np.int16).tobytes()

    @staticmethod
    def ai_to_fs(pcm16_bytes: bytes) -> bytes:
        \"\"\"PCM16LE 16kHz -> G.711a 8kHz\"\"\"
        if not pcm16_bytes:
            return b""
        pcm_8k = RESAMPLE_FUNC(
            np.frombuffer(pcm16_bytes, dtype=np.int16), AI_RATE, FS_RATE
        ).astype(np.int16)
        return pcm_to_pcma(pcm_8k)


class AudioFrameBuffer:
    \"\"\"将变长 PCM16LE 音频块切割为标准 20ms PCMA 帧。非线程安全。\"\"\"

    def __init__(self):
        self._raw = bytearray()

    def push_pcm16(self, pcm16_bytes: bytes):
        if pcm16_bytes:
            self._raw.extend(AudioConverter.ai_to_fs(pcm16_bytes))

    def pop_frames(self) -> List[bytes]:
        frames = []
        while len(self._raw) >= FRAME_PCMA:
            frames.append(bytes(self._raw[:FRAME_PCMA]))
            del self._raw[:FRAME_PCMA]
        return frames

    def flush(self) -> bytes:
        data = bytes(self._raw)
        self._raw.clear()
        return data

    def clear(self):
        self._raw.clear()

    def __len__(self) -> int:
        return len(self._raw)
"""

# esl.py 内容里有 ESL 协议需要的 \\n\\n，在这个字符串里必须写成 \\\\n\\\\n
# 但实际上我们用 f-string 写入时不涉及，只有 _raw_send 里的字面量需要注意
# 下面的字符串写入磁盘后，\\n 会变成 \n，这正是我们想要的
FILES["esl.py"] = """\"\"\"
esl.py  —  FreeSWITCH ESL 连接 v3.0
\"\"\"

import logging
import queue
import socket
import threading
import time
import uuid as uuid_mod
from concurrent.futures import ThreadPoolExecutor
from typing import Callable, Dict, List, Optional
from urllib.parse import unquote

import config

logger = logging.getLogger("ESL")


class ESLError(Exception):
    pass


class ESLConnection:

    CMD_TIMEOUT   = 10
    BGAPI_TIMEOUT = 30
    SUB_TIMEOUT   = 5
    RECV_BUF_SIZE = 65536

    def __init__(self, host: str, port: int, password: str):
        self.host     = host
        self.port     = port
        self.password = password

        self._sock: Optional[socket.socket] = None
        self._buf        = b""
        self._connected  = False
        self._running    = False

        self._send_lock     = threading.Lock()
        self._api_resp_q:  queue.Queue = queue.Queue()
        self._cmd_reply_q: queue.Queue = queue.Queue()
        self._bgapi_pending: Dict[str, queue.Queue] = {}
        self._bgapi_lock    = threading.Lock()
        self._callbacks: Dict[str, List[Callable]] = {}
        self._executor = ThreadPoolExecutor(
            max_workers=8, thread_name_prefix="esl-cb"
        )
        self._reader_thread: Optional[threading.Thread] = None
        self._subscribed_events: List[str] = []
        self._reconnect_count = 0

    @property
    def connected(self) -> bool:
        return self._connected

    def connect(self) -> bool:
        try:
            self._sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self._sock.settimeout(10)
            self._sock.connect((self.host, self.port))
            self._sock.settimeout(None)
            self._buf = b""

            headers = self._read_headers()
            if headers.get("Content-Type") != "auth/request":
                raise ESLError(f"Unexpected greeting: {headers}")

            self._raw_send(f"auth {self.password}\\n\\n")

            headers = self._read_headers()
            reply   = headers.get("Reply-Text", "")
            if not reply.startswith("+OK"):
                raise ESLError(f"Auth failed: {reply!r}")

            self._connected = True
            logger.info(f"ESL connected -> {self.host}:{self.port}")
            return True

        except Exception as e:
            logger.error(f"ESL connect failed: {e}")
            try:
                self._sock.close()
            except Exception:
                pass
            self._connected = False
            return False

    def start(self):
        self._running = True
        self._reader_thread = threading.Thread(
            target=self._event_loop, name="esl-reader", daemon=True
        )
        self._reader_thread.start()

    def stop(self):
        self._running   = False
        self._connected = False
        if self._sock:
            try:
                self._sock.close()
            except Exception:
                pass
        self._executor.shutdown(wait=False)

    def subscribe(self, *events: str):
        self._subscribed_events = list(events)
        self._do_subscribe(events)

    def _do_subscribe(self, events):
        event_str = " ".join(events)
        with self._send_lock:
            self._raw_send(f"event plain {event_str}\\n\\n")
        try:
            reply = self._cmd_reply_q.get(timeout=self.SUB_TIMEOUT)
            if "+OK" not in reply:
                logger.warning(f"subscribe reply: {reply!r}")
            else:
                logger.info(f"ESL subscribed: {event_str}")
        except queue.Empty:
            logger.warning("subscribe: no reply within timeout")

    def on(self, event_name: str, callback: Callable):
        self._callbacks.setdefault(event_name, []).append(callback)

    def send_command(self, cmd: str) -> str:
        with self._send_lock:
            self._raw_send(f"api {cmd}\\n\\n")
        try:
            return self._api_resp_q.get(timeout=self.CMD_TIMEOUT)
        except queue.Empty:
            raise ESLError(f"api timeout: {cmd!r}")

    def send_bgapi(self, cmd: str) -> str:
        job_uuid = str(uuid_mod.uuid4())
        resp_q: queue.Queue = queue.Queue()
        with self._bgapi_lock:
            self._bgapi_pending[job_uuid] = resp_q
        try:
            with self._send_lock:
                self._raw_send(f"bgapi {cmd}\\nJob-UUID: {job_uuid}\\n\\n")
            return resp_q.get(timeout=self.BGAPI_TIMEOUT)
        except queue.Empty:
            raise ESLError(f"bgapi timeout: {cmd!r}")
        finally:
            with self._bgapi_lock:
                self._bgapi_pending.pop(job_uuid, None)

    def send_bgapi_nowait(self, cmd: str):
        job_uuid = str(uuid_mod.uuid4())
        with self._send_lock:
            self._raw_send(f"bgapi {cmd}\\nJob-UUID: {job_uuid}\\n\\n")

    def _raw_send(self, data: str):
        self._sock.sendall(data.encode("utf-8"))

    def _read_exactly(self, n: int) -> bytes:
        while len(self._buf) < n:
            chunk = self._sock.recv(self.RECV_BUF_SIZE)
            if not chunk:
                raise ConnectionError("ESL socket closed")
            self._buf += chunk
        data, self._buf = self._buf[:n], self._buf[n:]
        return data

    def _read_line(self) -> str:
        while b"\\n" not in self._buf:
            chunk = self._sock.recv(self.RECV_BUF_SIZE)
            if not chunk:
                raise ConnectionError("ESL socket closed")
            self._buf += chunk
        idx = self._buf.index(b"\\n")
        line, self._buf = self._buf[:idx], self._buf[idx + 1:]
        return line.decode("utf-8", errors="replace").strip()

    def _read_headers(self) -> Dict[str, str]:
        headers: Dict[str, str] = {}
        while True:
            line = self._read_line()
            if line == "":
                break
            if ": " in line:
                k, v = line.split(": ", 1)
                headers[k.strip()] = unquote(v.strip())
        return headers

    def _read_body(self, length: int) -> str:
        if length <= 0:
            return ""
        return self._read_exactly(length).decode("utf-8", errors="replace")

    def _event_loop(self):
        logger.info("ESL event loop started")
        while self._running:
            try:
                headers = self._read_headers()
                if not headers:
                    continue
                ct   = headers.get("Content-Type", "")
                cl   = int(headers.get("Content-Length", 0))
                body = self._read_body(cl)

                if ct == "api/response":
                    self._api_resp_q.put(body.strip())
                elif ct == "command/reply":
                    self._cmd_reply_q.put(
                        headers.get("Reply-Text", body.strip())
                    )
                elif ct == "text/event-plain":
                    self._dispatch_event(body)
                elif ct == "text/disconnect-notice":
                    logger.warning("ESL disconnect notice")
                    self._connected = False
                    break
                elif ct == "auth/request":
                    pass
                elif ct:
                    logger.debug(f"ESL unhandled: {ct!r}")

            except ConnectionError as e:
                logger.error(f"ESL connection lost: {e}")
                break
            except Exception as e:
                if self._running:
                    logger.exception(f"ESL loop error: {e}")
                    time.sleep(0.05)

        self._connected = False
        logger.warning("ESL event loop exited")
        if self._running:
            self._schedule_reconnect()

    def _dispatch_event(self, body: str):
        event_headers: Dict[str, str] = {}
        for line in body.split("\\n"):
            stripped = line.strip()
            if stripped == "":
                break
            if ": " in stripped:
                k, v = stripped.split(": ", 1)
                event_headers[k.strip()] = unquote(v.strip())

        inner_cl   = int(event_headers.get("Content-Length", 0))
        inner_body = ""
        if inner_cl > 0:
            pos = body.find("\\n\\n")
            if pos != -1:
                inner_body = body[pos + 2: pos + 2 + inner_cl]
            else:
                pos = body.find("\\n")
                if pos != -1:
                    inner_body = body[pos + 1: pos + 1 + inner_cl]

        event_name = event_headers.get("Event-Name", "")

        if event_name == "BACKGROUND_JOB":
            job_uuid = event_headers.get("Job-UUID", "")
            with self._bgapi_lock:
                resp_q = self._bgapi_pending.get(job_uuid)
            if resp_q is not None:
                resp_q.put(inner_body.strip())
            return

        callbacks = self._callbacks.get(event_name, [])
        if callbacks:
            evt = {"headers": event_headers, "body": inner_body}
            for cb in callbacks:
                self._executor.submit(self._safe_call, cb, evt)

    @staticmethod
    def _safe_call(cb: Callable, event: dict):
        try:
            cb(event)
        except Exception as e:
            logger.exception(f"ESL callback [{cb.__name__}]: {e}")

    def _schedule_reconnect(self):
        threading.Thread(
            target=self._reconnect_loop,
            name="esl-reconnect",
            daemon=True,
        ).start()

    def _reconnect_loop(self):
        max_r    = getattr(config, "ESL_MAX_RECONNECTS", 0)
        interval = getattr(config, "ESL_RECONNECT_INTERVAL", 5)
        attempt  = 0
        while self._running:
            attempt += 1
            if max_r > 0 and attempt > max_r:
                logger.error(f"ESL max reconnects ({max_r}) reached")
                return
            wait = min(interval * (2 ** (attempt - 1)), 60)
            logger.info(f"ESL reconnect in {wait}s (attempt {attempt})...")
            time.sleep(wait)
            if not self._running:
                return
            if self.connect():
                self._reconnect_count += 1
                logger.info(f"ESL reconnected (total: {self._reconnect_count})")
                if self._subscribed_events:
                    self._do_subscribe(self._subscribed_events)
                self.start()
                return
            logger.warning(f"ESL reconnect attempt {attempt} failed")
"""

FILES["ai_client.py"] = """\"\"\"
ai_client.py  —  MiniCPM-o WebSocket 客户端 v3.0
\"\"\"

import asyncio
import base64
import json
import logging
import socket as _socket
import time
from enum import Enum, auto
from typing import Callable, Optional

import websockets
import websockets.exceptions

import config

logger = logging.getLogger("AIClient")

_SEND_TIMEOUT      = 5.0
_CONNECT_TIMEOUT   = 10.0
_HANDSHAKE_TIMEOUT = 15.0
_SEND_QUEUE_SIZE   = 200


class ClientState(Enum):
    DISCONNECTED = auto()
    CONNECTING   = auto()
    READY        = auto()
    CLOSING      = auto()


class AIClient:
    \"\"\"
    封装与 MiniCPM-o 的 WebSocket 会话。

    回调（事件循环线程同步调用，必须快速返回）：
      on_audio_chunk(pcm16_bytes)  on_turn_done()
      on_speech_started()          on_transcript(text)
      on_error(reason)             on_connected()
    \"\"\"

    def __init__(self, session_id: str):
        self.session_id = session_id
        self.mode       = config.AI_MODE
        self._state     = ClientState.DISCONNECTED
        self._ws        = None
        self._send_queue: asyncio.Queue = asyncio.Queue(maxsize=_SEND_QUEUE_SIZE)
        self._recv_task: Optional[asyncio.Task] = None
        self._send_task: Optional[asyncio.Task] = None
        self._connect_start:    float = 0.0
        self._first_audio_recv: float = 0.0

        self.on_audio_chunk:    Optional[Callable[[bytes], None]] = None
        self.on_turn_done:      Optional[Callable[[], None]]      = None
        self.on_speech_started: Optional[Callable[[], None]]      = None
        self.on_transcript:     Optional[Callable[[str], None]]   = None
        self.on_error:          Optional[Callable[[str], None]]   = None
        self.on_connected:      Optional[Callable[[], None]]      = None

    @property
    def connected(self) -> bool:
        return self._state == ClientState.READY

    @property
    def latency_connect_ms(self) -> float:
        if self._first_audio_recv > 0 and self._connect_start > 0:
            return (self._first_audio_recv - self._connect_start) * 1000
        return -1.0

    async def connect(self) -> bool:
        if self._state != ClientState.DISCONNECTED:
            return False
        self._state         = ClientState.CONNECTING
        self._connect_start = time.monotonic()

        headers = {}
        if self.mode == "cloud":
            headers["Authorization"] = f"Bearer {config.CLOUD_API_KEY}"

        try:
            self._ws = await asyncio.wait_for(
                websockets.connect(
                    config.MINICPM_WS_URL,
                    extra_headers=headers,
                    ping_interval=20,
                    ping_timeout=10,
                    max_size=16 * 1024 * 1024,
                    compression=None,
                ),
                timeout=_CONNECT_TIMEOUT,
            )
        except asyncio.TimeoutError:
            logger.error(f"[{self.session_id}] AI connect timeout")
            self._state = ClientState.DISCONNECTED
            return False
        except Exception as e:
            logger.error(f"[{self.session_id}] AI connect failed: {e}")
            self._state = ClientState.DISCONNECTED
            return False

        self._set_tcp_nodelay()

        try:
            await asyncio.wait_for(self._handshake(), timeout=_HANDSHAKE_TIMEOUT)
        except Exception as e:
            logger.error(f"[{self.session_id}] handshake failed: {e}")
            await self._ws.close()
            self._state = ClientState.DISCONNECTED
            return False

        self._recv_task = asyncio.create_task(
            self._recv_loop(), name=f"ai-recv-{self.session_id[:8]}"
        )
        self._send_task = asyncio.create_task(
            self._send_loop(), name=f"ai-send-{self.session_id[:8]}"
        )
        self._state = ClientState.READY
        elapsed = (time.monotonic() - self._connect_start) * 1000
        logger.info(f"[{self.session_id}] AI ready ({elapsed:.0f}ms)")
        self._fire(self.on_connected)
        return True

    def _set_tcp_nodelay(self):
        try:
            sock = self._ws.transport.get_extra_info("socket")
            if sock:
                sock.setsockopt(_socket.IPPROTO_TCP, _socket.TCP_NODELAY, 1)
                sock.setsockopt(_socket.SOL_SOCKET,  _socket.SO_KEEPALIVE, 1)
        except Exception as e:
            logger.debug(f"[{self.session_id}] TCP_NODELAY: {e}")

    async def close(self):
        if self._state == ClientState.CLOSING:
            return
        self._state = ClientState.CLOSING
        try:
            self._send_queue.put_nowait(None)
        except asyncio.QueueFull:
            pass
        for task in (self._send_task, self._recv_task):
            if task and not task.done():
                task.cancel()
                try:
                    await task
                except asyncio.CancelledError:
                    pass
        if self._ws:
            try:
                await asyncio.wait_for(self._ws.close(), timeout=2.0)
            except Exception:
                pass
            self._ws = None
        self._state = ClientState.DISCONNECTED
        logger.info(f"[{self.session_id}] AI closed")

    async def send_audio(self, pcm16_bytes: bytes):
        if self._state != ClientState.READY or not pcm16_bytes:
            return
        msg = (
            json.dumps({
                "type":  "input_audio_buffer.append",
                "audio": base64.b64encode(pcm16_bytes).decode(),
            })
            if self.mode == "cloud"
            else pcm16_bytes
        )
        await self._enqueue(msg)

    async def send_text(self, text: str):
        if self._state != ClientState.READY:
            return
        if self.mode == "cloud":
            for msg in (
                json.dumps({
                    "type": "conversation.item.create",
                    "item": {
                        "type": "message", "role": "user",
                        "content": [{"type": "input_text", "text": text}],
                    },
                }),
                json.dumps({"type": "response.create"}),
            ):
                await self._enqueue(msg)
        else:
            await self._enqueue(json.dumps({"type": "text_input", "text": text}))

    async def interrupt(self):
        if self._state != ClientState.READY:
            return
        try:
            payload = (
                json.dumps({"type": "input_audio_buffer.clear"})
                if self.mode == "cloud"
                else json.dumps({"type": "barge_in"})
            )
            await asyncio.wait_for(self._ws.send(payload), timeout=_SEND_TIMEOUT)
        except Exception as e:
            logger.error(f"[{self.session_id}] interrupt: {e}")

    async def _handshake(self):
        if self.mode == "cloud":
            await self._handshake_cloud()
        else:
            await self._handshake_local()

    async def _handshake_cloud(self):
        async for raw in self._ws:
            if json.loads(raw).get("type") == "session.created":
                break
        await self._ws.send(json.dumps({
            "type": "session.update",
            "session": {
                "instructions":        config.AI_SYSTEM_PROMPT,
                "voice":               config.AI_VOICE,
                "input_audio_format":  "pcm16",
                "output_audio_format": "pcm16",
                "turn_detection": {
                    "type": "server_vad", "threshold": 0.5,
                    "silence_duration_ms": 600,
                },
                "input_audio_transcription": {
                    "model": "whisper-1", "language": "zh",
                },
            },
        }))
        async for raw in self._ws:
            if json.loads(raw).get("type") == "session.updated":
                break

    async def _handshake_local(self):
        await self._ws.send(json.dumps({
            "type": "init", "session_id": self.session_id,
            "sample_rate": config.AI_SAMPLE_RATE,
            "channels": 1, "format": "pcm_s16le",
        }))
        async for raw in self._ws:
            if isinstance(raw, str):
                try:
                    if json.loads(raw).get("type") in ("ready", "init_ok"):
                        break
                except json.JSONDecodeError:
                    pass

    async def _send_loop(self):
        while True:
            try:
                msg = await self._send_queue.get()
            except asyncio.CancelledError:
                break
            if msg is None:
                break
            try:
                await asyncio.wait_for(self._ws.send(msg), timeout=_SEND_TIMEOUT)
            except asyncio.TimeoutError:
                logger.warning(f"[{self.session_id}] send timeout")
            except websockets.exceptions.ConnectionClosed:
                self._state = ClientState.DISCONNECTED
                break
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"[{self.session_id}] send: {e}")

    async def _recv_loop(self):
        try:
            async for msg in self._ws:
                if self._state == ClientState.CLOSING:
                    break
                if isinstance(msg, bytes):
                    self._record_first_audio()
                    self._fire(self.on_audio_chunk, msg)
                else:
                    self._dispatch_json(msg)
        except asyncio.CancelledError:
            pass
        except websockets.exceptions.ConnectionClosed as e:
            logger.warning(f"[{self.session_id}] WS closed: {e.code} {e.reason!r}")
        except Exception as e:
            logger.exception(f"[{self.session_id}] recv: {e}")
        finally:
            if self._state == ClientState.READY:
                self._state = ClientState.DISCONNECTED
                self._fire(self.on_error, "connection_lost")

    def _dispatch_json(self, raw: str):
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            return
        t = data.get("type", "")
        if t == "response.output_audio.delta":
            chunk = base64.b64decode(data.get("delta", ""))
            if chunk:
                self._record_first_audio()
                self._fire(self.on_audio_chunk, chunk)
        elif t == "response.output_audio.done":
            self._fire(self.on_turn_done)
        elif t == "input_audio_buffer.speech_started":
            self._fire(self.on_speech_started)
        elif t == "conversation.item.input_audio_transcription.completed":
            text = data.get("transcript", "").strip()
            if text:
                self._fire(self.on_transcript, text)
        elif t == "error":
            logger.error(f"[{self.session_id}] AI error: {data.get('error')}")
            self._fire(self.on_error, str(data.get("error", "")))

    def _record_first_audio(self):
        if self._first_audio_recv == 0:
            self._first_audio_recv = time.monotonic()
            ms = (self._first_audio_recv - self._connect_start) * 1000
            logger.info(f"[{self.session_id}] First audio: {ms:.0f}ms")

    async def _enqueue(self, msg):
        try:
            self._send_queue.put_nowait(msg)
        except asyncio.QueueFull:
            try:
                self._send_queue.get_nowait()
                self._send_queue.put_nowait(msg)
            except (asyncio.QueueEmpty, asyncio.QueueFull):
                pass

    def _fire(self, cb: Optional[Callable], *args):
        if cb is None:
            return
        try:
            cb(*args)
        except Exception as e:
            logger.exception(f"[{self.session_id}] callback {cb.__name__}: {e}")
