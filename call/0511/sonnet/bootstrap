FILES["session.py"] = """\"\"\"
session.py  —  通话会话 v3.0
\"\"\"

import asyncio
import json
import logging
import os
import queue
import select
import shutil
import socket as _socket
import tempfile
import threading
import time
from dataclasses import dataclass, field
from typing import Any, Dict, List, Optional

import websockets
import websockets.exceptions

from audio import AudioConverter, AudioFrameBuffer, FRAME_PCMA
from ai_client import AIClient

logger = logging.getLogger("Session")

FLUSH_MIN_MS     = 200
FLUSH_MIN_BYTES  = 8_000 * FLUSH_MIN_MS // 1000
FLUSH_MAX_SEC    = 0.4
FIFO_OPEN_TIMEOUT = 15.0
KEEP_AUDIO_FILES = 20


class AudioStreamHandler:
    def __init__(self, session: "CallSession",
                 ws: websockets.WebSocketServerProtocol):
        self._session = session
        self._ws      = ws
        self._running = True

    async def run(self):
        r = asyncio.create_task(self._recv_from_fs())
        s = asyncio.create_task(self._send_to_fs())
        done, pending = await asyncio.wait(
            {r, s}, return_when=asyncio.FIRST_COMPLETED
        )
        for t in pending:
            t.cancel()
            try:
                await t
            except asyncio.CancelledError:
                pass

    async def stop(self):
        self._running = False

    async def _recv_from_fs(self):
        try:
            async for msg in self._ws:
                if not self._running:
                    break
                if isinstance(msg, bytes):
                    if not msg:
                        continue
                    self._session.audio_in_bytes += len(msg)
                    if self._session._metrics:
                        self._session._metrics.audio_frames_in.inc()
                    try:
                        self._session.fs_to_ai_queue.put_nowait(msg)
                    except queue.Full:
                        if self._session._metrics:
                            self._session._metrics.audio_drop_total.labels(direction="in").inc()
                        try:
                            self._session.fs_to_ai_queue.get_nowait()
                            self._session.fs_to_ai_queue.put_nowait(msg)
                        except queue.Empty:
                            pass
                else:
                    await self._handle_ctrl(msg)
        except (websockets.exceptions.ConnectionClosed, asyncio.CancelledError):
            pass
        except Exception as e:
            logger.error(f"[{self._session.uuid}] stream recv: {e}")

    async def _handle_ctrl(self, raw: str):
        try:
            ctrl  = json.loads(raw)
            event = ctrl.get("event", "")
            if event == "start":
                logger.info(f"[{self._session.uuid}] stream start: {ctrl}")
            elif event == "stop":
                self._running = False
            elif event == "dtmf":
                digit = ctrl.get("digit", "")
                if digit:
                    self._session.on_dtmf(digit)
        except Exception as e:
            logger.warning(f"[{self._session.uuid}] ctrl: {e}")

    async def _send_to_fs(self):
        loop = asyncio.get_running_loop()
        while self._running:
            try:
                frame = await loop.run_in_executor(
                    None,
                    lambda: self._session.ai_to_fs_queue.get(timeout=0.02),
                )
                if frame is None:
                    break
                await self._ws.send(frame)
                self._session.audio_out_bytes += len(frame)
                if self._session._metrics:
                    self._session._metrics.audio_frames_out.inc()
            except queue.Empty:
                continue
            except (websockets.exceptions.ConnectionClosed, asyncio.CancelledError):
                break
            except Exception as e:
                logger.error(f"[{self._session.uuid}] stream send: {e}")


class AudioStreamServer:
    def __init__(self, host: str = "0.0.0.0", port: int = 8081):
        self._host     = host
        self._port     = port
        self._server   = None
        self._registry: Dict[str, Any] = {}

    async def start(self):
        self._server = await websockets.serve(
            self._on_connect, self._host, self._port,
            compression=None, max_size=1 * 1024 * 1024,
        )
        logger.info(f"AudioStreamServer -> ws://{self._host}:{self._port}")

    async def stop(self):
        if self._server:
            self._server.close()
            await self._server.wait_closed()

    def register(self, call_uuid: str, session: "CallSession"):
        self._registry[call_uuid] = session

    def unregister(self, call_uuid: str):
        self._registry.pop(call_uuid, None)

    async def _on_connect(self, ws: websockets.WebSocketServerProtocol, path: str):
        try:
            sock = ws.transport.get_extra_info("socket")
            if sock:
                sock.setsockopt(_socket.IPPROTO_TCP, _socket.TCP_NODELAY, 1)
        except Exception as e:
            logger.debug(f"TCP_NODELAY: {e}")

        call_uuid = path.lstrip("/")
        if not call_uuid:
            await ws.close()
            return

        session = self._registry.get(call_uuid)
        if not isinstance(session, CallSession):
            logger.warning(f"No session for {call_uuid!r}")
            await ws.close()
            return

        logger.info(f"[{call_uuid}] AudioStream connected")
        handler = AudioStreamHandler(session, ws)
        session._stream_handler = handler
        self._registry[call_uuid] = handler
        await handler.run()
        session._stream_handler = None
        logger.info(f"[{call_uuid}] AudioStream disconnected")


@dataclass
class CallSession:
    uuid:          str
    direction:     str
    caller_number: str
    callee_number: str
    created_at:    float = field(default_factory=time.time)

    fs_to_ai_queue: queue.Queue = field(default_factory=lambda: queue.Queue(maxsize=500))
    ai_to_fs_queue: queue.Queue = field(default_factory=lambda: queue.Queue(maxsize=500))

    is_active:        bool  = field(default=True)
    is_answered:      bool  = field(default=False)
    is_ai_speaking:   bool  = field(default=False)
    use_audio_stream: bool  = field(default=True)
    audio_in_bytes:   int   = field(default=0)
    audio_out_bytes:  int   = field(default=0)
    barge_in_count:   int   = field(default=0)
    ai_latency_ms:    float = field(default=-1.0)

    ai_client:       Optional[AIClient]                  = field(default=None,                      init=False)
    _loop:           Optional[asyncio.AbstractEventLoop] = field(default=None,                      init=False)
    _esl_ref:        Any                                 = field(default=None,                      init=False)
    _threads:        List[threading.Thread]              = field(default_factory=list,               init=False)
    _fifo_path:      str                                 = field(default="",                        init=False)
    _tmp_dir:        str                                 = field(default="",                        init=False)
    _frame_buf:      AudioFrameBuffer                    = field(default_factory=AudioFrameBuffer,  init=False)
    _hangup_lock:    threading.Lock                      = field(default_factory=threading.Lock,    init=False)
    _barge_lock:     threading.Lock                      = field(default_factory=threading.Lock,    init=False)
    _stream_handler: Optional[AudioStreamHandler]        = field(default=None,                      init=False)
    _metrics:        Optional[Any]                       = field(default=None,                      init=False)

    def start(self, loop, esl_conn, metrics=None, audio_server=None):
        import weakref
        self._loop    = loop
        self._esl_ref = weakref.ref(esl_conn)
        self._metrics = metrics

        if audio_server is not None:
            self.use_audio_stream = True
            audio_server.register(self.uuid, self)
            logger.info(f"[{self.uuid}] Mode: mod_audio_stream")
        else:
            self.use_audio_stream = False
            self._tmp_dir = tempfile.mkdtemp(prefix=f"ai_{self.uuid[:8]}_")
            t = threading.Thread(target=self._play_loop_fifo,
                                 name=f"play-{self.uuid[:8]}", daemon=True)
            t.start()
            self._threads.append(t)
            logger.info(f"[{self.uuid}] Mode: FIFO (fallback)")

        asyncio.run_coroutine_threadsafe(self._ai_main(), self._loop)
        if self._metrics:
            self._metrics.active_calls.inc()

    def start_fifo(self):
        t = threading.Thread(target=self._fifo_read_loop,
                             name=f"fifo-{self.uuid[:8]}", daemon=True)
        t.start()
        self._threads.append(t)

    def hangup(self, reason: str = "normal"):
        with self._hangup_lock:
            if not self.is_active:
                return
            self.is_active = False

        logger.info(f"[{self.uuid}] Hangup: {reason}")
        if self._stream_handler and self._loop and self._loop.is_running():
            asyncio.run_coroutine_threadsafe(self._stream_handler.stop(), self._loop)
        if self.ai_client and self._loop and self._loop.is_running():
            asyncio.run_coroutine_threadsafe(self.ai_client.close(), self._loop)
        for t in self._threads:
            t.join(timeout=3)
        if self._fifo_path and os.path.exists(self._fifo_path):
            try: os.remove(self._fifo_path)
            except OSError: pass
        if self._tmp_dir and os.path.exists(self._tmp_dir):
            shutil.rmtree(self._tmp_dir, ignore_errors=True)
        if self._metrics:
            self._metrics.active_calls.dec()
            self._metrics.call_duration.observe(time.time() - self.created_at)
        logger.info(
            f"[{self.uuid}] Done | in={self.audio_in_bytes}B "
            f"out={self.audio_out_bytes}B barge={self.barge_in_count} "
            f"latency={self.ai_latency_ms:.0f}ms"
        )

    def on_answered(self):
        self.is_answered = True

    def on_dtmf(self, digit: str):
        logger.info(f"[{self.uuid}] DTMF: {digit!r}")
        if digit in ("*", "#"):
            self.barge_in()
        elif self.ai_client and self._loop:
            asyncio.run_coroutine_threadsafe(
                self.ai_client.send_text(f"用户按键：{digit}"), self._loop
            )

    def barge_in(self):
        with self._barge_lock:
            if not self.is_ai_speaking:
                return
            self.is_ai_speaking = False
        self.barge_in_count += 1
        logger.info(f"[{self.uuid}] Barge-in #{self.barge_in_count}")
        if not self.use_audio_stream:
            esl = self._esl_ref() if self._esl_ref else None
            if esl:
                try:
                    esl.send_bgapi_nowait(f"uuid_break {self.uuid} all")
                except Exception as e:
                    logger.warning(f"[{self.uuid}] uuid_break: {e}")
        if self.ai_client and self._loop:
            asyncio.run_coroutine_threadsafe(self.ai_client.interrupt(), self._loop)
        self._drain_audio()
        if self._metrics:
            self._metrics.barge_in_total.inc()

    def _fifo_read_loop(self):
        fd = -1
        try:
            fd = os.open(self._fifo_path, os.O_RDONLY | os.O_NONBLOCK)
            ready, _, _ = select.select([fd], [], [], FIFO_OPEN_TIMEOUT)
            if not ready:
                logger.error(f"[{self.uuid}] FIFO timeout")
                self.hangup("fifo_timeout")
                return
            os.set_blocking(fd, True)
            while self.is_active:
                try:
                    data = os.read(fd, FRAME_PCMA)
                except BlockingIOError:
                    time.sleep(0.005)
                    continue
                if not data:
                    break
                self.audio_in_bytes += len(data)
                if self._metrics:
                    self._metrics.audio_frames_in.inc()
                try:
                    self.fs_to_ai_queue.put_nowait(data)
                except queue.Full:
                    if self._metrics:
                        self._metrics.audio_drop_total.labels(direction="in").inc()
                    try:
                        self.fs_to_ai_queue.get_nowait()
                        self.fs_to_ai_queue.put_nowait(data)
                    except queue.Empty:
                        pass
        except Exception as e:
            if self.is_active:
                logger.error(f"[{self.uuid}] FIFO: {e}")
        finally:
            if fd >= 0:
                try: os.close(fd)
                except OSError: pass

    async def _ai_main(self):
        client = AIClient(self.uuid)
        client.on_audio_chunk    = self._on_ai_audio
        client.on_turn_done      = self._on_ai_turn_done
        client.on_speech_started = self._on_speech_started
        client.on_transcript     = self._on_transcript
        client.on_error          = self._on_ai_error
        client.on_connected      = self._on_ai_connected
        self.ai_client = client

        if not await client.connect():
            if self._metrics:
                self._metrics.ai_errors_total.labels(reason="connect_failed").inc()
            self.hangup("ai_connect_failed")
            return

        if self.direction == "outbound":
            await client.send_text("你好，我是智能客服，请问有什么可以帮您？")

        await self._send_to_ai_loop()

    async def _send_to_ai_loop(self):
        loop      = asyncio.get_running_loop()
        converter = AudioConverter()
        while self.is_active and self.ai_client and self.ai_client.connected:
            try:
                pcma = await loop.run_in_executor(
                    None, lambda: self.fs_to_ai_queue.get(timeout=0.05)
                )
            except queue.Empty:
                continue
            except Exception as e:
                logger.error(f"[{self.uuid}] queue: {e}")
                break
            try:
                await self.ai_client.send_audio(converter.fs_to_ai(pcma))
            except Exception as e:
                logger.error(f"[{self.uuid}] AI send: {e}")
                break

    def _on_ai_connected(self):
        if self.ai_client:
            self.ai_latency_ms = self.ai_client.latency_connect_ms
        if self._metrics and self.ai_latency_ms > 0:
            self._metrics.ai_connect_latency.observe(self.ai_latency_ms / 1000.0)

    def _on_ai_audio(self, pcm16_bytes: bytes):
        self.is_ai_speaking = True
        self._frame_buf.push_pcm16(pcm16_bytes)
        for frame in self._frame_buf.pop_frames():
            try:
                self.ai_to_fs_queue.put_nowait(frame)
            except queue.Full:
                if self._metrics:
                    self._metrics.audio_drop_total.labels(direction="out").inc()
                try:
                    self.ai_to_fs_queue.get_nowait()
                    self.ai_to_fs_queue.put_nowait(frame)
                except queue.Empty:
                    pass

    def _on_ai_turn_done(self):
        tail = self._frame_buf.flush()
        if tail:
            try: self.ai_to_fs_queue.put_nowait(tail)
            except queue.Full: pass

    def _on_speech_started(self):
        if self.is_ai_speaking:
            self.barge_in()

    def _on_transcript(self, text: str):
        logger.info(f"[{self.uuid}] User: {text}")
        if self._metrics:
            self._metrics.transcripts_total.inc()

    def _on_ai_error(self, reason: str):
        logger.error(f"[{self.uuid}] AI error: {reason!r}")
        if self._metrics:
            self._metrics.ai_errors_total.labels(reason=reason).inc()
        if self.is_active:
            self.hangup(f"ai_error:{reason}")

    def _play_loop_fifo(self):
        buf = bytearray()
        last_data = last_flush = time.monotonic()
        while self.is_active:
            try:
                frame = self.ai_to_fs_queue.get(timeout=0.02)
                buf.extend(frame)
                last_data = time.monotonic()
            except queue.Empty:
                pass
            now = time.monotonic()
            qe  = self.ai_to_fs_queue.empty()
            if buf and (
                len(buf) >= FLUSH_MIN_BYTES
                or (qe and now - last_data  >= 0.08)
                or (now - last_flush >= FLUSH_MAX_SEC)
            ):
                self._flush_to_fs(bytes(buf))
                buf.clear()
                last_flush = now
                if qe:
                    self.is_ai_speaking = False
        if buf:
            self._flush_to_fs(bytes(buf))

    def _flush_to_fs(self, data: bytes):
        esl = self._esl_ref() if self._esl_ref else None
        if not esl or not self._tmp_dir:
            return
        fname = os.path.join(self._tmp_dir, f"{int(time.monotonic()*1_000_000)}.pcma")
        try:
            with open(fname, "wb") as f:
                f.write(data)
            esl.send_bgapi_nowait(f"uuid_broadcast {self.uuid} {fname} aleg")
        except Exception as e:
            logger.error(f"[{self.uuid}] flush: {e}")
            return
        self._cleanup_old_files()

    def _cleanup_old_files(self):
        if not self._tmp_dir or not os.path.exists(self._tmp_dir):
            return
        try:
            files = sorted(
                (f for f in os.listdir(self._tmp_dir) if f.endswith(".pcma")),
                key=lambda f: os.path.getmtime(os.path.join(self._tmp_dir, f)),
            )
            for old in files[:-KEEP_AUDIO_FILES]:
                try: os.remove(os.path.join(self._tmp_dir, old))
                except OSError: pass
        except Exception:
            pass

    def _drain_audio(self):
        for q in (self.ai_to_fs_queue, self.fs_to_ai_queue):
            while not q.empty():
                try: q.get_nowait()
                except queue.Empty: break
        self._frame_buf.clear()

    def to_dict(self) -> dict:
        return {
            "uuid":            self.uuid,
            "direction":       self.direction,
            "caller":          self.caller_number,
            "callee":          self.callee_number,
            "is_active":       self.is_active,
            "is_answered":     self.is_answered,
            "is_ai_speaking":  self.is_ai_speaking,
            "ai_connected":    self.ai_client.connected if self.ai_client else False,
            "audio_mode":      "stream" if self.use_audio_stream else "fifo",
            "audio_in_bytes":  self.audio_in_bytes,
            "audio_out_bytes": self.audio_out_bytes,
            "barge_in_count":  self.barge_in_count,
            "ai_latency_ms":   round(self.ai_latency_ms, 1),
            "duration_sec":    round(time.time() - self.created_at, 1),
        }
"""

FILES["api.py"] = """\"\"\"
api.py  —  FastAPI HTTP 路由 v3.0
\"\"\"

import asyncio
import logging
import uuid as uuid_mod
from typing import Optional

from fastapi import FastAPI, HTTPException, Request
from fastapi.responses import JSONResponse

import config

logger  = logging.getLogger("API")
api_app = FastAPI(title="MiniCPM-o Gateway", version="3.0")

_mgr = _esl = _metrics = None
_loop: Optional[asyncio.AbstractEventLoop] = None


def init(session_mgr, esl_conn, loop, metrics=None):
    global _mgr, _esl, _loop, _metrics
    _mgr, _esl, _loop, _metrics = session_mgr, esl_conn, loop, metrics


@api_app.exception_handler(Exception)
async def _exc(request: Request, exc: Exception):
    logger.exception(f"API error: {exc}")
    return JSONResponse(status_code=500, content={"detail": "Internal server error"})


@api_app.get("/")
async def root():
    return {"service": "MiniCPM-o Gateway", "version": "3.0", "ai_mode": config.AI_MODE}


@api_app.get("/health")
async def health():
    return {
        "esl_connected":   _esl.connected if _esl else False,
        "active_sessions": len(_mgr.sessions) if _mgr else 0,
        "ai_mode":         config.AI_MODE,
        "audio_mode":      "mod_audio_stream" if getattr(config, "USE_AUDIO_STREAM", True) else "fifo",
    }


@api_app.get("/sessions")
async def list_sessions():
    if not _mgr:
        return {"count": 0, "sessions": []}
    return {"count": len(_mgr.sessions), "sessions": _mgr.list_active()}


@api_app.get("/sessions/{call_uuid}")
async def get_session(call_uuid: str):
    if not _mgr:
        raise HTTPException(503, "Not initialized")
    s = _mgr.get(call_uuid)
    if not s:
        raise HTTPException(404, "Session not found")
    return s.to_dict()


@api_app.post("/call")
async def make_call(request: dict):
    phone = str(request.get("phone_number", "")).strip()
    if not phone:
        raise HTTPException(400, "phone_number required")
    call_uuid = str(uuid_mod.uuid4())
    cmd = (
        f"originate {{origination_uuid={call_uuid},"
        f"origination_caller_id_number={request.get('caller_id', config.OUTBOUND_CID)},"
        f"origination_caller_id_name=AI,ignore_early_media=true}}"
        f" sofia/gateway/{request.get('gateway', config.FXO_GATEWAY)}/{phone} &park"
    )
    try:
        result = await asyncio.get_running_loop().run_in_executor(None, _esl.send_command, cmd)
    except Exception as e:
        raise HTTPException(503, f"ESL error: {e}")
    return {"status": "initiated", "call_uuid": call_uuid, "phone_number": phone, "fs_result": result}


@api_app.post("/call/{call_uuid}/hangup")
async def hangup_call(call_uuid: str):
    if not _esl:
        raise HTTPException(503, "Not initialized")
    _esl.send_bgapi_nowait(f"uuid_kill {call_uuid}")
    return {"status": "hangup_sent"}


@api_app.post("/call/{call_uuid}/barge_in")
async def barge_in(call_uuid: str):
    s = _mgr.get(call_uuid) if _mgr else None
    if not s:
        raise HTTPException(404, "Session not found")
    s.barge_in()
    return {"status": "barge_in_triggered"}


@api_app.post("/call/{call_uuid}/say")
async def say_text(call_uuid: str, request: dict):
    s = _mgr.get(call_uuid) if _mgr else None
    if not s:
        raise HTTPException(404, "Session not found")
    text = str(request.get("text", "")).strip()
    if not text:
        raise HTTPException(400, "text required")
    if s.ai_client and _loop:
        asyncio.run_coroutine_threadsafe(s.ai_client.send_text(text), _loop)
    return {"status": "sent"}
"""

FILES["main.py"] = """\"\"\"
main.py  —  网关入口 v3.0
\"\"\"

import asyncio
import glob
import logging
import os
import shutil
import threading
import time
from contextlib import asynccontextmanager
from typing import Dict, List, Optional

import uvicorn

import config
from audio_utils import log_audio_backend
from esl import ESLConnection
from session import CallSession, AudioStreamServer
from metrics import GatewayMetrics
from api import api_app, init as api_init

logger = logging.getLogger("Main")
ALLOWED_CONTEXTS = frozenset({"public", "default"})


def cleanup_stale_files():
    count = sum(
        1 for p in (
            *glob.glob("/tmp/minicpm_*.pcma"),
            *glob.glob("/tmp/ai_*_*/"),
        )
        for _ in [shutil.rmtree(p, ignore_errors=True)
                  if os.path.isdir(p) else os.remove(p)
                  if os.path.exists(p) else None]
    )
    if count:
        logger.info(f"Cleaned {count} stale temp files")


class SessionManager:
    def __init__(self):
        self.sessions: Dict[str, CallSession] = {}
        self._lock = threading.RLock()

    def create(self, uuid, direction, caller, callee) -> CallSession:
        with self._lock:
            if uuid in self.sessions:
                return self.sessions[uuid]
            s = CallSession(uuid=uuid, direction=direction,
                            caller_number=caller, callee_number=callee)
            self.sessions[uuid] = s
            return s

    def get(self, uuid) -> Optional[CallSession]:
        with self._lock:
            return self.sessions.get(uuid)

    def remove(self, uuid):
        with self._lock:
            self.sessions.pop(uuid, None)

    def list_active(self) -> List[dict]:
        with self._lock:
            return [s.to_dict() for s in self.sessions.values()]


class GatewayEventHandler:
    def __init__(self, mgr, esl, loop, metrics, audio_server):
        self._mgr = mgr; self._esl = esl; self._loop = loop
        self._metrics = metrics; self._audio_server = audio_server

    def on_channel_create(self, event: dict):
        h = event["headers"]
        ctx = h.get("Caller-Context", "")
        if ctx not in ALLOWED_CONTEXTS:
            return
        self._mgr.create(
            h.get("Unique-ID", ""),
            h.get("Call-Direction", "unknown"),
            h.get("Caller-Caller-ID-Number", "unknown"),
            h.get("Caller-Destination-Number", "unknown"),
        )
        logger.info(
            f"[ESL] CREATE {h.get('Unique-ID')} "
            f"({h.get('Call-Direction')}) "
            f"{h.get('Caller-Caller-ID-Number')} -> "
            f"{h.get('Caller-Destination-Number')}"
        )

    def on_channel_answer(self, event: dict):
        h         = event["headers"]
        call_uuid = h.get("Unique-ID", "")
        session   = self._mgr.get(call_uuid)
        if not session:
            return
        session.on_answered()

        if self._audio_server is not None:
            session.start(loop=self._loop, esl_conn=self._esl,
                          metrics=self._metrics, audio_server=self._audio_server)
        else:
            fifo = f"/tmp/minicpm_{call_uuid}.pcma"
            try:
                os.mkfifo(fifo)
            except FileExistsError:
                pass
            except OSError as e:
                logger.error(f"[{call_uuid}] mkfifo: {e}")
                return
            session._fifo_path = fifo
            try:
                self._esl.send_bgapi_nowait(f"uuid_record {call_uuid} start {fifo} 1800")
            except Exception as e:
                logger.error(f"[{call_uuid}] uuid_record: {e}")
                return
            session.start_fifo()
            session.start(loop=self._loop, esl_conn=self._esl,
                          metrics=self._metrics, audio_server=None)

        self._metrics.calls_total.labels(
            direction=session.direction, result="started"
        ).inc()
        logger.info(f"[ESL] ANSWER {call_uuid}")

    def on_channel_hangup(self, event: dict):
        h         = event["headers"]
        call_uuid = h.get("Unique-ID", "")
        cause     = h.get("Hangup-Cause", "UNKNOWN")
        session   = self._mgr.get(call_uuid)
        if session:
            if self._audio_server:
                self._audio_server.unregister(call_uuid)
            session.hangup(cause)
            self._mgr.remove(call_uuid)
            self._metrics.calls_total.labels(
                direction=session.direction, result="ended"
            ).inc()
        logger.info(f"[ESL] HANGUP {call_uuid} cause={cause}")

    def on_dtmf(self, event: dict):
        h         = event["headers"]
        call_uuid = h.get("Unique-ID", "")
        digit     = h.get("DTMF-Digit", "")
        session   = self._mgr.get(call_uuid)
        if session and digit:
            session.on_dtmf(digit)


def build_app():
    @asynccontextmanager
    async def lifespan(app):
        loop = asyncio.get_running_loop()
        logging.basicConfig(
            level=getattr(logging, config.LOG_LEVEL, logging.INFO),
            format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
            datefmt="%H:%M:%S",
        )
        cleanup_stale_files()
        log_audio_backend()

        metrics = GatewayMetrics()
        metrics.start_http_server(getattr(config, "METRICS_PORT", 9090))

        use_stream   = getattr(config, "USE_AUDIO_STREAM", True)
        audio_server = None
        if use_stream:
            audio_server = AudioStreamServer(
                host=getattr(config, "STREAM_WS_HOST", "0.0.0.0"),
                port=getattr(config, "STREAM_WS_PORT", 8081),
            )
            await audio_server.start()

        esl = ESLConnection(config.FS_HOST, config.FS_ESL_PORT, config.FS_ESL_PASS)
        if not esl.connect():
            raise RuntimeError("ESL connection failed")
        metrics.esl_connected.set(1)

        mgr     = SessionManager()
        handler = GatewayEventHandler(mgr, esl, loop, metrics, audio_server)

        esl.on("CHANNEL_CREATE",  handler.on_channel_create)
        esl.on("CHANNEL_ANSWER",  handler.on_channel_answer)
        esl.on("CHANNEL_HANGUP",  handler.on_channel_hangup)
        esl.on("DTMF",            handler.on_dtmf)
        esl.subscribe("CHANNEL_CREATE","CHANNEL_ANSWER",
                      "CHANNEL_HANGUP","DTMF","BACKGROUND_JOB")
        esl.start()
        api_init(mgr, esl, loop, metrics)

        logger.info("=" * 54)
        logger.info("  MiniCPM-o Gateway v3.0  ready")
        logger.info(f"  AI      : {config.AI_MODE} @ {config.MINICPM_WS_URL}")
        logger.info(f"  ESL     : {config.FS_HOST}:{config.FS_ESL_PORT}")
        logger.info(f"  API     : http://0.0.0.0:{config.API_PORT}")
        logger.info(f"  Mode    : {'mod_audio_stream' if use_stream else 'FIFO'}")
        if use_stream:
            logger.info(f"  Stream  : ws://0.0.0.0:{getattr(config,'STREAM_WS_PORT',8081)}")
        logger.info(f"  Metrics : http://0.0.0.0:{getattr(config,'METRICS_PORT',9090)}/metrics")
        logger.info("=" * 54)

        yield

        logger.info("Shutting down...")
        with mgr._lock:
            sessions = list(mgr.sessions.values())
        for s in sessions:
            s.hangup("server_shutdown")
        if audio_server:
            await audio_server.stop()
        esl.stop()
        metrics.esl_connected.set(0)
        logger.info("Shutdown complete")

    api_app.router.lifespan_context = lifespan
    return api_app


def main():
    uvicorn.run(
        build_app(),
        host="0.0.0.0",
        port=getattr(config, "API_PORT", 8080),
        log_level="warning",
    )


if __name__ == "__main__":
    main()
"""

