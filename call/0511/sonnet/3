  AI 连接延迟   : histogram_quantile(0.95, minicpm_ai_connect_latency_bucket)
  音频丢帧率    : rate(minicpm_audio_drop_total[1m])
  打断次数      : rate(minicpm_barge_in_total[5m])
"""

import logging

logger = logging.getLogger("Metrics")

try:
    from prometheus_client import (
        Counter,
        Gauge,
        Histogram,
        Info,
        start_http_server as _start_http,
    )
    _AVAILABLE = True
except ImportError:
    _AVAILABLE = False
    logger.warning(
        "prometheus_client not installed, metrics disabled. "
        "Run: pip install prometheus-client"
    )


class _Noop:
