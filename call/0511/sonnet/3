## `esl.py`

```python
"""
esl.py  ─  FreeSWITCH ESL 连接 v3.0

修复：
  [1] 单一读取线程，彻底消除 socket 竞态
  [2] Content-Type 路由，api/response → Queue，event-plain → 回调
  [3] BACKGROUND_JOB 内层 body 正确解析（\\n\\n → \n\n）
  [4] subscribe 通过专用 _cmd_reply_q 等待确认
  [5] ESL 断线自动重连（指数退避）
  [6] 重连后自动重新订阅
"""

import logging
import queue
import socket
import threading
import time
import uuid as uuid_mod
from concurrent.futures import ThreadPoolExecutor
from typing import Callable, Dict, List, Optional, Tuple
from urllib.parse import unquote

import config

logger = logging.getLogger("ESL")


class ESLError(Exception):
    pass


class ESLConnection:
    """
    线程安全的 FreeSWITCH ESL 连接。

    消息流（事件循环线程是唯一读取 socket 的地方）：
        写：send_command / send_bgapi
              → _send_lock
              → socket.sendall
        读：_event_loop（唯一）
              → Content-Type 路由
              → api/response     → _api_resp_q
              → command/reply    → _cmd_reply_q
              → text/event-plain → _dispatch_event → 回调线程池
    """

    CMD_TIMEOUT   = 10
    BGAPI_TIMEOUT = 30
    SUB_TIMEOUT   = 5
    RECV_BUF_SIZE = 65536

    def __init__(self, host: str, port: int, password: str):
        self.host     = host
        self.port     = port
        self.password = password

        self._sock: Optional[socket.socket] = None
        self._buf        = b""
        self._connected  = False
        self._running    = False

        # 发送互斥锁
        self._send_lock = threading.Lock()

        # 响应队列
        self._api_resp_q:  queue.Queue = queue.Queue()
        self._cmd_reply_q: queue.Queue = queue.Queue()

        # bgapi job_uuid → Queue 路由表
        self._bgapi_pending: Dict[str, queue.Queue] = {}
        self._bgapi_lock    = threading.Lock()

        # 事件回调注册表
        self._callbacks: Dict[str, List[Callable]] = {}

        # 回调线程池（与读取线程解耦，避免慢回调阻塞读取）
        self._executor = ThreadPoolExecutor(
            max_workers=8,
            thread_name_prefix="esl-cb",
        )

        self._reader_thread: Optional[threading.Thread] = None

        # 重连状态
        self._subscribed_events: List[str] = []
        self._reconnect_count = 0

    # ------------------------------------------------------------------ #
    #  属性
    # ------------------------------------------------------------------ #

    @property
    def connected(self) -> bool:
        return self._connected

    # ------------------------------------------------------------------ #
    #  公开接口
    # ------------------------------------------------------------------ #

    def connect(self) -> bool:
        """
        建立 TCP 连接并完成 ESL auth 握手。
        事件循环启动前调用，直接读写 socket 安全。
        """
        try:
            self._sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self._sock.settimeout(10)
            self._sock.connect((self.host, self.port))
            self._sock.settimeout(None)
            self._buf = b""

            # 等待 auth/request
            headers = self._read_headers()
            ct = headers.get("Content-Type", "")
            if ct != "auth/request":
                raise ESLError(f"Unexpected greeting: {ct!r}")

            # 发送密码
            self._raw_send(f"auth {self.password}\n\n")

            # 读取 command/reply
            headers = self._read_headers()
            reply   = headers.get("Reply-Text", "")
            if not reply.startswith("+OK"):
                raise ESLError(f"Auth failed: {reply!r}")

            self._connected = True
            logger.info(f"ESL connected → {self.host}:{self.port}")
            return True

        except Exception as e:
            logger.error(f"ESL connect failed: {e}")
            try:
                self._sock.close()
            except Exception:
                pass
            self._connected = False
            return False

    def start(self):
        """启动后台事件循环线程，必须在 connect() 成功后调用。"""
        self._running = True
        self._reader_thread = threading.Thread(
            target=self._event_loop,
            name="esl-reader",
            daemon=True,
        )
        self._reader_thread.start()

    def stop(self):
        """优雅关闭。"""
        self._running   = False
        self._connected = False
        if self._sock:
            try:
                self._sock.close()
            except Exception:
                pass
        self._executor.shutdown(wait=False)

    def subscribe(self, *events: str):
        """
        订阅 ESL 事件，等待 command/reply 确认后返回。
        缓存订阅列表以便断线重连后恢复。
        """
        self._subscribed_events = list(events)
        self._do_subscribe(events)

    def _do_subscribe(self, events):
        event_str = " ".join(events)
        with self._send_lock:
            self._raw_send(f"event plain {event_str}\n\n")
        try:
            reply = self._cmd_reply_q.get(timeout=self.SUB_TIMEOUT)
            if "+OK" not in reply:
                logger.warning(f"subscribe reply unexpected: {reply!r}")
            else:
                logger.info(f"ESL subscribed: {event_str}")
        except queue.Empty:
            logger.warning("subscribe: no reply within timeout")

    def on(self, event_name: str, callback: Callable):
        """注册事件回调，线程安全。"""
        self._callbacks.setdefault(event_name, []).append(callback)

    def send_command(self, cmd: str) -> str:
        """
        发送同步 api 命令，阻塞等待响应。
        线程安全，可从任意线程调用。
        """
        with self._send_lock:
            self._raw_send(f"api {cmd}\n\n")
        try:
            return self._api_resp_q.get(timeout=self.CMD_TIMEOUT)
        except queue.Empty:
            raise ESLError(f"api command timeout: {cmd!r}")

    def send_bgapi(self, cmd: str) -> str:
        """
        发送 bgapi 命令，阻塞等待 BACKGROUND_JOB 结果。
        线程安全，可从任意线程调用。
        """
        job_uuid = str(uuid_mod.uuid4())
        resp_q: queue.Queue = queue.Queue()

        with self._bgapi_lock:
            self._bgapi_pending[job_uuid] = resp_q

        try:
            with self._send_lock:
                self._raw_send(
                    f"bgapi {cmd}\nJob-UUID: {job_uuid}\n\n"
                )
            return resp_q.get(timeout=self.BGAPI_TIMEOUT)
        except queue.Empty:
            raise ESLError(f"bgapi timeout: {cmd!r}")
        finally:
            with self._bgapi_lock:
                self._bgapi_pending.pop(job_uuid, None)

    def send_bgapi_nowait(self, cmd: str):
        """发送 bgapi，不等待结果（fire-and-forget）。线程安全。"""
        job_uuid = str(uuid_mod.uuid4())
        with self._send_lock:
            self._raw_send(
                f"bgapi {cmd}\nJob-UUID: {job_uuid}\n\n"
            )

    # ------------------------------------------------------------------ #
    #  内部：socket 读写原语
    # ------------------------------------------------------------------ #

    def _raw_send(self, data: str):
        """直接写 socket。调用方必须持有 _send_lock（connect 阶段除外）。"""
        self._sock.sendall(data.encode("utf-8"))

    def _read_exactly(self, n: int) -> bytes:
        """从内部缓冲区读取精确 n 字节。"""
        while len(self._buf) < n:
            chunk = self._sock.recv(self.RECV_BUF_SIZE)
            if not chunk:
                raise ConnectionError("ESL socket closed")
            self._buf += chunk
        data, self._buf = self._buf[:n], self._buf[n:]
        return data

    def _read_line(self) -> str:
        """读取一行（以 \\n 结尾），返回去除首尾空白的字符串。"""
        while b"\n" not in self._buf:
            chunk = self._sock.recv(self.RECV_BUF_SIZE)
            if not chunk:
                raise ConnectionError("ESL socket closed")
            self._buf += chunk
        idx         = self._buf.index(b"\n")
        line, self._buf = self._buf[:idx], self._buf[idx + 1:]
        return line.decode("utf-8", errors="replace").strip()

    def _read_headers(self) -> Dict[str, str]:
        """
        读取 ESL 头部块（连续 key: value 行，以空行结束）。
        对值做 URL 解码（ESL 对特殊字符做 %XX 编码）。
        """
        headers: Dict[str, str] = {}
        while True:
            line = self._read_line()
            if line == "":
                break
            if ": " in line:
                k, v = line.split(": ", 1)
                headers[k.strip()] = unquote(v.strip())
        return headers

    def _read_body(self, length: int) -> str:
        """按 Content-Length 读取消息体。"""
        if length <= 0:
            return ""
        return self._read_exactly(length).decode("utf-8", errors="replace")

    # ------------------------------------------------------------------ #
    #  内部：事件循环（唯一读取 socket 的线程）
    # ------------------------------------------------------------------ #

    def _event_loop(self):
        """
        永久循环，按 Content-Type 路由每条 ESL 消息。

        Content-Type            路由
        ─────────────────────── ────────────────────────────
        auth/request            忽略（connect 阶段已处理）
        command/reply           → _cmd_reply_q
        api/response            → _api_resp_q
        text/event-plain        → _dispatch_event()
        text/disconnect-notice  → 触发重连
        """
        logger.info("ESL event loop started")
        while self._running:
            try:
                headers = self._read_headers()
                if not headers:
                    continue

                ct   = headers.get("Content-Type", "")
                cl   = int(headers.get("Content-Length", 0))
                body = self._read_body(cl)

                if ct == "api/response":
                    self._api_resp_q.put(body.strip())

                elif ct == "command/reply":
                    reply = headers.get("Reply-Text", body.strip())
                    self._cmd_reply_q.put(reply)

                elif ct == "text/event-plain":
                    self._dispatch_event(body)

                elif ct == "text/disconnect-notice":
                    logger.warning("ESL disconnect notice received")
                    self._connected = False
                    break

                elif ct == "auth/request":
                    pass  # 重连时可能再次收到，忽略

                else:
                    if ct:
                        logger.debug(f"ESL unhandled Content-Type: {ct!r}")

            except ConnectionError as e:
                logger.error(f"ESL connection lost: {e}")
                break
            except Exception as e:
                if self._running:
                    logger.exception(f"ESL event loop error: {e}")
                    time.sleep(0.05)

        self._connected = False
        logger.warning("ESL event loop exited")

        # 触发自动重连
        if self._running:
            self._schedule_reconnect()

    def _dispatch_event(self, body: str):
        """
        解析 text/event-plain 消息体，路由到回调或 bgapi 等待队列。

        ESL text/event-plain 格式：
          body = 事件头部（key: value 行）+ 空行 + 内层 body
          内层 body 长度由事件头部的 Content-Length 指定
          BACKGROUND_JOB 的执行结果在内层 body 中
        """
        # 解析事件头部（body 中第一个空行之前）
        event_headers: Dict[str, str] = {}
        lines = body.split("\n")
        split_idx = len(lines)

        for i, line in enumerate(lines):
            stripped = line.strip()
            if stripped == "":
                split_idx = i
                break
            if ": " in stripped:
                k, v = stripped.split(": ", 1)
                event_headers[k.strip()] = unquote(v.strip())

        # 解析内层 body
        # 修复：使用真正的 \n\n（两个换行符），不是转义序列
        inner_cl   = int(event_headers.get("Content-Length", 0))
        inner_body = ""
        if inner_cl > 0:
            # 在原始 body 字符串中定位空行分隔符
            split_pos = body.find("\n\n")
            if split_pos != -1:
                inner_body = body[split_pos + 2: split_pos + 2 + inner_cl]
            else:
                # 部分 ESL 实现用单换行分隔
                split_pos = body.find("\n")
                if split_pos != -1:
                    inner_body = body[split_pos + 1: split_pos + 1 + inner_cl]

        event_name = event_headers.get("Event-Name", "")

        # BACKGROUND_JOB：路由给等待的 send_bgapi 调用
        if event_name == "BACKGROUND_JOB":
            job_uuid = event_headers.get("Job-UUID", "")
            with self._bgapi_lock:
                resp_q = self._bgapi_pending.get(job_uuid)
            if resp_q is not None:
                resp_q.put(inner_body.strip())
            return

        # 普通事件：在线程池执行回调，不阻塞读取循环
        callbacks = self._callbacks.get(event_name, [])
        if callbacks:
            event = {
                "headers": event_headers,
                "body":    inner_body,
            }
            for cb in callbacks:
                self._executor.submit(self._safe_call, cb, event)

    @staticmethod
    def _safe_call(cb: Callable, event: dict):
        try:
            cb(event)
        except Exception as e:
            logger.exception(f"ESL callback error [{cb.__name__}]: {e}")

    # ------------------------------------------------------------------ #
    #  内部：断线重连
    # ------------------------------------------------------------------ #

    def _schedule_reconnect(self):
        """在独立线程中执行重连，不阻塞事件循环线程。"""
        t = threading.Thread(
            target=self._reconnect_loop,
            name="esl-reconnect",
            daemon=True,
        )
        t.start()

    def _reconnect_loop(self):
        """指数退避重连，成功后重新订阅事件。"""
        max_retries = getattr(config, "ESL_MAX_RECONNECTS", 0)
        interval    = getattr(config, "ESL_RECONNECT_INTERVAL", 5)
        attempt     = 0

        while self._running:
            attempt += 1
            if max_retries > 0 and attempt > max_retries:
                logger.error(f"ESL max reconnects ({max_retries}) reached, giving up")
                return

            # 指数退避：5s, 10s, 20s, 最大 60s
            wait = min(interval * (2 ** (attempt - 1)), 60)
            logger.info(f"ESL reconnect attempt {attempt} in {wait}s...")
            time.sleep(wait)

            if not self._running:
                return

            logger.info(f"ESL reconnecting to {self.host}:{self.port}...")
            if self.connect():
                self._reconnect_count += 1
                logger.info(
                    f"ESL reconnected (attempt {attempt}, "
                    f"total reconnects: {self._reconnect_count})"
                )
                # 重新订阅之前订阅过的事件
                if self._subscribed_events:
                    self._do_subscribe(self._subscribed_events)
                # 重启事件循环线程
                self.start()
                return
            else:
                logger.warning(f"ESL reconnect attempt {attempt} failed")
