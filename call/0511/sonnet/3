"""
audio_utils.py  ─  G.711a 编解码 + 重采样

依赖优先级：
  G.711a : audioop（内置）→ audioop-lts（3.13+）→ pyg711
  重采样  : soxr → scipy → 线性插值（最差）

安装建议：
  Python <= 3.12 : pip install soxr
  Python >= 3.13 : pip install soxr audioop-lts
"""

import logging
import sys

import numpy as np

logger = logging.getLogger("AudioUtils")

# ── G.711a 编解码 ────────────────────────────────────────────────────────

def _load_alaw_codec():
    """按优先级加载 G.711a 编解码实现。"""

    # 方案 1：audioop（Python 内置，3.13 前）
    try:
        import audioop as _audioop

        def _alaw2lin(data: bytes) -> bytes:
            return _audioop.alaw2lin(data, 2)

        def _lin2alaw(data: bytes) -> bytes:
            return _audioop.lin2alaw(data, 2)

        logger.debug("G.711a codec: audioop (built-in)")
        return _alaw2lin, _lin2alaw
    except ImportError:
        pass

    # 方案 2：audioop-lts（Python 3.13+ 替代包）
    try:
        import audioop_lts as _audioop

        def _alaw2lin(data: bytes) -> bytes:
            return _audioop.alaw2lin(data, 2)

        def _lin2alaw(data: bytes) -> bytes:
            return _audioop.lin2alaw(data, 2)

        logger.debug("G.711a codec: audioop-lts")
        return _alaw2lin, _lin2alaw
    except ImportError:
        pass

    # 方案 3：pyg711
    try:
        import g711

        def _alaw2lin(data: bytes) -> bytes:
            samples = g711.decode_alaw(np.frombuffer(data, dtype=np.uint8))
            return samples.astype(np.int16).tobytes()

        def _lin2alaw(data: bytes) -> bytes:
            samples = np.frombuffer(data, dtype=np.int16)
            return g711.encode_alaw(samples).tobytes()

        logger.debug("G.711a codec: pyg711")
        return _alaw2lin, _lin2alaw
    except ImportError:
        pass

    # 方案 4：纯 Python 查表（最后手段，仅用于测试）
    logger.warning(
        "No G.711a library found. Using pure-Python fallback (low quality). "
        "Install: pip install soxr audioop-lts"
    )
    return _alaw2lin_fallback, _lin2alaw_fallback


def _alaw2lin_fallback(data: bytes) -> bytes:
    """G.711a → PCM16 纯 Python 实现（仅测试用）。"""
    ALAW_TO_LINEAR = _build_alaw_table()
    out = np.array([ALAW_TO_LINEAR[b] for b in data], dtype=np.int16)
    return out.tobytes()


def _lin2alaw_fallback(data: bytes) -> bytes:
    """PCM16 → G.711a 纯 Python 实现（仅测试用）。"""
    samples = np.frombuffer(data, dtype=np.int16)
    out = np.array([_encode_alaw_sample(int(s)) for s in samples], dtype=np.uint8)
    return out.tobytes()


def _build_alaw_table():
    """构建 G.711a 解码查找表（256 个条目）。"""
    table = np.zeros(256, dtype=np.int16)
    for i in range(256):
        a = i ^ 0x55
        seg = (a & 0x70) >> 4
        val = a & 0x0F
        if seg == 0:
            val = (val << 1) | 1
        else:
            val = ((val | 0x10) << seg)
        table[i] = -val if (a & 0x80) == 0 else val
    return table


def _encode_alaw_sample(sample: int) -> int:
    sign = 0 if sample < 0 else 0x80
    if sample < 0:
        sample = -sample - 1
    sample = min(sample, 32767)
    if sample < 256:
        encoded = sample >> 4
        seg = 0
    else:
        for seg in range(1, 8):
            if sample < (256 << seg):
                break
        encoded = (sample >> (seg + 3)) & 0x0F
    return (sign | (seg << 4) | encoded) ^ 0x55


_alaw2lin_bytes, _lin2alaw_bytes = _load_alaw_codec()


# ── 重采样 ───────────────────────────────────────────────────────────────

def _load_resample():
    """按优先级加载重采样实现。"""

    # 方案 1：soxr（最高质量，推荐）
    try:
        import soxr

        def _resample(data: np.ndarray, src: int, dst: int) -> np.ndarray:
            if src == dst:
                return data
            out = soxr.resample(
                data.astype(np.float32), src, dst, quality="HQ"
            )
            return np.clip(out, -32768, 32767).astype(np.int16)

        logger.debug("Resampler: soxr (HQ)")
        return _resample
    except ImportError:
        pass

    # 方案 2：scipy
    try:
        from scipy import signal as _signal

        def _resample(data: np.ndarray, src: int, dst: int) -> np.ndarray:
            if src == dst:
                return data
            from math import gcd
            g   = gcd(src, dst)
            up  = dst // g
            down = src // g
            out = _signal.resample_poly(data.astype(np.float64), up, down)
            return np.clip(out, -32768, 32767).astype(np.int16)

        logger.debug("Resampler: scipy.signal.resample_poly")
        return _resample
    except ImportError:
        pass

    # 方案 3：线性插值（最差，有明显失真）
    logger.warning(
        "No high-quality resampler found. Using linear interpolation. "
        "Install: pip install soxr"
    )

    def _resample(data: np.ndarray, src: int, dst: int) -> np.ndarray:
        if src == dst:
            return data
        ratio      = dst / src
        new_length = int(len(data) * ratio)
        if new_length == 0:
            return np.zeros(1, dtype=np.int16)
        indices = np.linspace(0, len(data) - 1, new_length)
        out     = np.interp(indices, np.arange(len(data)), data)
        return np.clip(out, -32768, 32767).astype(np.int16)

    return _resample


RESAMPLE_FUNC = _load_resample()


# ── 公开接口 ─────────────────────────────────────────────────────────────

def pcma_to_pcm(pcma_bytes: bytes) -> np.ndarray:
    """
    G.711a（A-law）字节串 → PCM16LE ndarray。

    Args:
        pcma_bytes: G.711a 编码的字节数据
    Returns:
        PCM16LE numpy 数组
    """
    pcm_bytes = _alaw2lin_bytes(pcma_bytes)
    return np.frombuffer(pcm_bytes, dtype=np.int16).copy()


def pcm_to_pcma(pcm: np.ndarray) -> bytes:
    """
    PCM16LE ndarray → G.711a（A-law）字节串。

    Args:
        pcm: PCM16LE numpy 数组
    Returns:
        G.711a 编码的字节数据
    """
    pcm_bytes = pcm.astype(np.int16).tobytes()
    return _lin2alaw_bytes(pcm_bytes)


def log_audio_backend():
    """启动时打印音频后端信息（供 main.py 调用）。"""
    py_ver = sys.version_info
    logger.info(
        f"Audio backend ready | "
        f"Python {py_ver.major}.{py_ver.minor}.{py_ver.micro}"
    )
