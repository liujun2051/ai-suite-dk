<include>
  <extension name="minicpm_ai_inbound">
    <!-- 匹配呼入号码，按需修改 -->
    <condition field="destination_number" expression="^(5000|5001|5002)$">

      <action application="answer"/>
      <!-- 等待线路稳定 -->
      <action application="sleep" data="300"/>

      <!-- mod_audio_stream 模式：将通话音频双向流式传输到网关 -->
      <!-- ${uuid} 会展开为本次通话的唯一 ID，网关用它路由到对应 session -->
      <action application="audio_stream"
              data="ws://127.0.0.1:8081/${uuid} 8000 mono"/>

      <action application="hangup"/>
    </condition>
  </extension>

  <!-- 外呼接听后进入 AI 处理 -->
  <extension name="minicpm_ai_outbound_answer">
    <condition field="call_direction" expression="outbound">
      <condition field="answer_state" expression="answered">
        <action application="audio_stream"
                data="ws://127.0.0.1:8081/${uuid} 8000 mono"/>
      </condition>
    </condition>
  </extension>
</include>
