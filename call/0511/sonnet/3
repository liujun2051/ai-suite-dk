STREAM_WS_PORT_DEFAULT = 8081


# ======================================================================
#  AudioStreamHandler：处理单路通话的 WebSocket 连接
# ======================================================================

class AudioStreamHandler:
    """
    处理 FreeSWITCH mod_audio_stream 建立的单路 WebSocket 连接。

    协议：
      FS → 程序：二进制 PCMA 帧 / JSON 控制消息（start/stop/dtmf）
      程序 → FS：二进制 PCMA 帧（AI 回复音频）
    """

    def __init__(self,
                 session: "CallSession",
                 ws:      websockets.WebSocketServerProtocol):
        self._session = session
        self._ws      = ws
        self._running = True

    async def run(self):
        recv_task = asyncio.create_task(self._recv_from_fs())
        send_task = asyncio.create_task(self._send_to_fs())
        try:
            done, pending = await asyncio.wait(
                {recv_task, send_task},
                return_when=asyncio.FIRST_COMPLETED,
            )
            for t in pending:
                t.cancel()
                try:
                    await t
                except asyncio.CancelledError:
                    pass
        except Exception as e:
            logger.error(f"[{self._session.uuid}] AudioStream run error: {e}")

    async def stop(self):
        self._running = False

    async def _recv_from_fs(self):
        """接收 FS 推来的音频帧和控制消息。"""
        try:
            async for msg in self._ws:
                if not self._running:
                    break

                if isinstance(msg, bytes):
                    if not msg:
                        continue
                    self._session.audio_in_bytes += len(msg)
                    if self._session._metrics:
                        self._session._metrics.audio_frames_in.inc()
                    try:
                        self._session.fs_to_ai_queue.put_nowait(msg)
                    except queue.Full:
                        if self._session._metrics:
                            self._session._metrics.audio_drop_total.labels(
                                direction="in"
                            ).inc()
                        try:
                            self._session.fs_to_ai_queue.get_nowait()
                            self._session.fs_to_ai_queue.put_nowait(msg)
                        except queue.Empty:
                            pass

                else:
                    await self._handle_ctrl(msg)

        except websockets.exceptions.ConnectionClosed:
            pass
        except asyncio.CancelledError:
            pass
        except Exception as e:
            logger.error(
                f"[{self._session.uuid}] AudioStream recv error: {e}"
            )

    async def _handle_ctrl(self, raw: str):
        """处理 JSON 控制帧。"""
        try:
            ctrl  = json.loads(raw)
            event = ctrl.get("event", "")
            if event == "start":
                logger.info(
                    f"[{self._session.uuid}] AudioStream start: {ctrl}"
                )
            elif event == "stop":
                logger.info(
                    f"[{self._session.uuid}] AudioStream stop"
                )
                self._running = False
            elif event == "dtmf":
                digit = ctrl.get("digit", "")
                if digit:
                    self._session.on_dtmf(digit)
        except Exception as e:
            logger.warning(
                f"[{self._session.uuid}] ctrl parse error: {e}"
            )

    async def _send_to_fs(self):
        """
        从 ai_to_fs_queue 取 PCMA 帧，直接通过 WebSocket 发给 FS。
        这是低延迟的关键：无文件 IO，无 uuid_broadcast ESL 往返。
        """
        loop = asyncio.get_running_loop()
        while self._running:
            try:
                frame = await loop.run_in_executor(
                    None,
                    lambda: self._session.ai_to_fs_queue.get(timeout=0.02),
                )
                if frame is None:
                    break
                await self._ws.send(frame)
                self._session.audio_out_bytes += len(frame)
                if self._session._metrics:
                    self._session._metrics.audio_frames_out.inc()
            except queue.Empty:
                continue
            except websockets.exceptions.ConnectionClosed:
                break
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(
                    f"[{self._session.uuid}] AudioStream send error: {e}"
                )


# ======================================================================
#  AudioStreamServer：WebSocket 服务器
# ======================================================================

class AudioStreamServer:
    """
    监听 FreeSWITCH mod_audio_stream 的 WebSocket 连接。

    修复：移除无效的 create_connection 参数，改为在 _on_connect 中
    连接建立后设置 TCP_NODELAY。

    FS Dialplan 配置示例：
      <action application="audio_stream"
              data="ws://127.0.0.1:8081/${uuid} 8000 mono"/>
                                              ↑↑↑↑↑↑
                                              UUID 作为 path，用于路由到对应 session
    """

    def __init__(self,
                 host: str = STREAM_WS_HOST_DEFAULT,
                 port: int = STREAM_WS_PORT_DEFAULT):
        self._host    = host
        self._port    = port
        self._server  = None

        # call_uuid → CallSession（等待连接）or AudioStreamHandler（已连接）
        self._registry: Dict[str, Any] = {}
        self._lock = asyncio.Lock()

    async def start(self):
        """启动 WebSocket 服务器。"""
        # 修复：不传 create_connection 参数，websockets.serve 没有此参数
        self._server = await websockets.serve(
            self._on_connect,
            self._host,
            self._port,
            compression=None,          # 关闭压缩，降低延迟
            max_size=1 * 1024 * 1024,  # 1MB 足够
        )
        logger.info(
            f"AudioStreamServer → ws://{self._host}:{self._port}"
        )

    async def stop(self):
        """关闭服务器。"""
        if self._server:
            self._server.close()
            await self._server.wait_closed()

    def register(self, call_uuid: str, session: "CallSession"):
        """CHANNEL_ANSWER 时注册 session，等待 FS 来连接。"""
        self._registry[call_uuid] = session

    def unregister(self, call_uuid: str):
        """CHANNEL_HANGUP 时注销。"""
        self._registry.pop(call_uuid, None)

    async def _on_connect(self,
                          ws:   websockets.WebSocketServerProtocol,
                          path: str):
        """
        FS 建立 WebSocket 连接时调用。
        path 格式：/{call_uuid}

        修复：TCP_NODELAY 在这里（连接建立后）设置。
        """
        # 设置 TCP_NODELAY（连接建立后）
        try:
            transport = ws.transport
            if transport:
                sock = transport.get_extra_info("socket")
                if sock:
                    sock.setsockopt(
                        _socket.IPPROTO_TCP,
                        _socket.TCP_NODELAY,
                        1,
                    )
        except Exception as e:
            logger.debug(f"AudioStream TCP_NODELAY: {e}")

        call_uuid = path.lstrip("/")
        if not call_uuid:
            logger.warning("AudioStream: missing call_uuid in path")
            await ws.close()
            return

        session = self._registry.get(call_uuid)
        if not isinstance(session, CallSession):
            logger.warning(f"AudioStream: no session for {call_uuid!r}")
            await ws.close()
            return

        logger.info(f"[{call_uuid}] AudioStream WebSocket connected")

        handler = AudioStreamHandler(session, ws)
        session._stream_handler = handler
        self._registry[call_uuid] = handler   # 替换为 handler

        await handler.run()

        session._stream_handler = None
        logger.info(f"[{call_uuid}] AudioStream WebSocket disconnected")


# ======================================================================
#  CallSession
# ======================================================================

@dataclass
class CallSession:
    """
    单路通话完整状态。

    所有字段必须有类型注解，确保 dataclass 正确生成实例变量（非类变量）。
    """

    # ── 构造时传入 ──────────────────────────────────────────────────────
    uuid:          str
    direction:     str
    caller_number: str
    callee_number: str

    # ── 时间戳 ──────────────────────────────────────────────────────────
    created_at: float = field(default_factory=time.time)

    # ── 音频队列 ────────────────────────────────────────────────────────
    fs_to_ai_queue: queue.Queue = field(
        default_factory=lambda: queue.Queue(maxsize=500)
    )
    ai_to_fs_queue: queue.Queue = field(
        default_factory=lambda: queue.Queue(maxsize=500)
    )

    # ── 状态 ────────────────────────────────────────────────────────────
    is_active:        bool = field(default=True)
    is_answered:      bool = field(default=False)
    is_ai_speaking:   bool = field(default=False)
    use_audio_stream: bool = field(default=True)

    # ── 统计 ────────────────────────────────────────────────────────────
    audio_in_bytes:  int   = field(default=0)
    audio_out_bytes: int   = field(default=0)
    barge_in_count:  int   = field(default=0)
    ai_latency_ms:   float = field(default=-1.0)

    # ── 内部对象（init=False，不暴露给构造方） ─────────────────────────
    ai_client:       Optional[AIClient]                  = field(default=None,                      init=False)
    _loop:           Optional[asyncio.AbstractEventLoop] = field(default=None,                      init=False)
    _esl_ref:        Any                                 = field(default=None,                      init=False)
    _threads:        List[threading.Thread]              = field(default_factory=list,               init=False)
    _fifo_path:      str                                 = field(default="",                        init=False)
    _tmp_dir:        str                                 = field(default="",                        init=False)
    _frame_buf:      AudioFrameBuffer                    = field(default_factory=AudioFrameBuffer,  init=False)
    _hangup_lock:    threading.Lock                      = field(default_factory=threading.Lock,    init=False)
    _barge_lock:     threading.Lock                      = field(default_factory=threading.Lock,    init=False)
    _stream_handler: Optional[AudioStreamHandler]        = field(default=None,                      init=False)
    _metrics:        Optional[Any]                       = field(default=None,                      init=False)

    # ================================================================== #
    #  生命周期
    # ================================================================== #

    def start(self,
              loop:         asyncio.AbstractEventLoop,
              esl_conn:     Any,
              metrics:      Optional[Any]                  = None,
              audio_server: Optional[AudioStreamServer]    = None):
        """
        启动会话工作线程和 AI 协程。

        FIFO 模式调用顺序（修复 [2]）：
          外部调用方应先 send_bgapi_nowait(uuid_record)，
          再 session.start_fifo()，
          最后 session.start()。
          本方法内部不再主动调用 start_fifo，职责分离。
        """
        import weakref
        self._loop    = loop
        self._esl_ref = weakref.ref(esl_conn)
        self._metrics = metrics

        if audio_server is not None:
            self.use_audio_stream = True
            audio_server.register(self.uuid, self)
            logger.info(
                f"[{self.uuid}] Mode: mod_audio_stream"
            )
        else:
            self.use_audio_stream = False
            self._tmp_dir = tempfile.mkdtemp(
                prefix=f"ai_{self.uuid[:8]}_"
            )
            # FIFO 降级模式：播放线程
            t_play = threading.Thread(
                target=self._play_loop_fifo,
                name=f"play-{self.uuid[:8]}",
                daemon=True,
            )
            t_play.start()
            self._threads.append(t_play)
            logger.info(f"[{self.uuid}] Mode: FIFO (fallback)")

        # AI 主协程
        asyncio.run_coroutine_threadsafe(self._ai_main(), self._loop)

        if self._metrics:
            self._metrics.active_calls.inc()

    def start_fifo(self):
        """
        FIFO 降级模式：启动读取线程。
        必须在 uuid_record 命令发出之后调用。
        """
        t = threading.Thread(
            target=self._fifo_read_loop,
            name=f"fifo-{self.uuid[:8]}",
            daemon=True,
        )
        t.start()
        self._threads.append(t)

    def hangup(self, reason: str = "normal"):
        """挂断并清理所有资源，幂等。"""
        with self._hangup_lock:
            if not self.is_active:
                return
            self.is_active = False

        logger.info(f"[{self.uuid}] Hangup: {reason}")

        if self._stream_handler:
            if self._loop and self._loop.is_running():
                asyncio.run_coroutine_threadsafe(
                    self._stream_handler.stop(), self._loop
                )

        if self.ai_client and self._loop and self._loop.is_running():
            asyncio.run_coroutine_threadsafe(
                self.ai_client.close(), self._loop
            )

        for t in self._threads:
            t.join(timeout=3)

        if self._fifo_path and os.path.exists(self._fifo_path):
            try:
                os.remove(self._fifo_path)
            except OSError:
                pass

        if self._tmp_dir and os.path.exists(self._tmp_dir):
            shutil.rmtree(self._tmp_dir, ignore_errors=True)

        if self._metrics:
            self._metrics.active_calls.dec()
            self._metrics.call_duration.observe(
                time.time() - self.created_at
            )

        logger.info(
            f"[{self.uuid}] Cleanup done | "
            f"in={self.audio_in_bytes}B "
            f"out={self.audio_out_bytes}B "
            f"barge_in={self.barge_in_count} "
            f"ai_latency={self.ai_latency_ms:.0f}ms"
        )

    # ================================================================== #
    #  ESL 事件入口（从 ESL 回调线程调用）
    # ================================================================== #

    def on_answered(self):
        self.is_answered = True

    def on_dtmf(self, digit: str):
        logger.info(f"[{self.uuid}] DTMF: {digit!r}")
        if digit in ("*", "#"):
            self.barge_in()
        elif self.ai_client and self._loop:
            asyncio.run_coroutine_threadsafe(
                self.ai_client.send_text(f"用户按键：{digit}"),
                self._loop,
            )

    def barge_in(self):
        """打断 AI，状态门控，幂等。"""
        with self._barge_lock:
            if not self.is_ai_speaking:
                return
            self.is_ai_speaking = False

        self.barge_in_count += 1
        logger.info(f"[{self.uuid}] Barge-in #{self.barge_in_count}")

        # FIFO 模式需要通知 FS 停止播放
        # mod_audio_stream 模式清空队列即可，FS 不会继续播放已丢弃的帧
        if not self.use_audio_stream:
            esl = self._esl_ref() if self._esl_ref else None
            if esl:
                try:
                    esl.send_bgapi_nowait(
                        f"uuid_break {self.uuid} all"
                    )
                except Exception as e:
                    logger.warning(
                        f"[{self.uuid}] uuid_break failed: {e}"
                    )

        if self.ai_client and self._loop:
            asyncio.run_coroutine_threadsafe(
                self.ai_client.interrupt(), self._loop
            )

        self._drain_audio()

        if self._metrics:
            self._metrics.barge_in_total.inc()

    # ================================================================== #
    #  FIFO 读取线程
    # ================================================================== #

    def _fifo_read_loop(self):
        """
        以阻塞方式读取 FS 写入 FIFO 的 G.711a 音频。
        非阻塞打开 + select 超时，防止 FS 未启动时永久挂起。
        """
        fd = -1
        try:
            fd = os.open(self._fifo_path, os.O_RDONLY | os.O_NONBLOCK)
            ready, _, _ = select.select([fd], [], [], FIFO_OPEN_TIMEOUT)
            if not ready:
                logger.error(
                    f"[{self.uuid}] FIFO not ready after "
                    f"{FIFO_OPEN_TIMEOUT}s"
                )
                self.hangup("fifo_timeout")
                return

            os.set_blocking(fd, True)
            logger.info(f"[{self.uuid}] FIFO read started")

            while self.is_active:
                try:
                    data = os.read(fd, FRAME_PCMA)
                except BlockingIOError:
                    time.sleep(0.005)
                    continue
                if not data:
                    logger.info(f"[{self.uuid}] FIFO EOF")
                    break

                self.audio_in_bytes += len(data)
                if self._metrics:
                    self._metrics.audio_frames_in.inc()

                try:
                    self.fs_to_ai_queue.put_nowait(data)
                except queue.Full:
                    if self._metrics:
                        self._metrics.audio_drop_total.labels(
                            direction="in"
                        ).inc()
                    try:
                        self.fs_to_ai_queue.get_nowait()
                        self.fs_to_ai_queue.put_nowait(data)
                    except queue.Empty:
                        pass

        except Exception as e:
            if self.is_active:
                logger.error(f"[{self.uuid}] FIFO error: {e}")
        finally:
            if fd >= 0:
                try:
                    os.close(fd)
                except OSError:
                    pass
            logger.info(f"[{self.uuid}] FIFO read loop exited")

    # ================================================================== #
    #  AI 主协程
    # ================================================================== #

    async def _ai_main(self):
        client = AIClient(self.uuid)
        client.on_audio_chunk    = self._on_ai_audio
        client.on_turn_done      = self._on_ai_turn_done
        client.on_speech_started = self._on_speech_started
        client.on_transcript     = self._on_transcript
        client.on_error          = self._on_ai_error
        client.on_connected      = self._on_ai_connected
        self.ai_client = client

        if not await client.connect():
            if self._metrics:
                self._metrics.ai_errors_total.labels(
                    reason="connect_failed"
                ).inc()
            self.hangup("ai_connect_failed")
            return

        if self.direction == "outbound":
            await client.send_text(
                "你好，我是智能客服，请问有什么可以帮您？"
            )

        await self._send_to_ai_loop()

    async def _send_to_ai_loop(self):
        """
        持续从 fs_to_ai_queue 读取 PCMA 帧，转换后发给 AI。
        用 run_in_executor 包装阻塞的 queue.get，不阻塞事件循环。
        """
        loop      = asyncio.get_running_loop()
        converter = AudioConverter()

        while self.is_active and self.ai_client and self.ai_client.connected:
            try:
                pcma = await loop.run_in_executor(
                    None,
                    lambda: self.fs_to_ai_queue.get(timeout=0.05),
                )
            except queue.Empty:
                continue
            except Exception as e:
                logger.error(f"[{self.uuid}] queue read error: {e}")
                break

            try:
                pcm16 = converter.fs_to_ai(pcma)
                await self.ai_client.send_audio(pcm16)
            except Exception as e:
                logger.error(f"[{self.uuid}] AI send error: {e}")
                break

    # ================================================================== #
    #  AI 回调（事件循环线程，必须快速返回）
    # ================================================================== #

    def _on_ai_connected(self):
        if self.ai_client:
            self.ai_latency_ms = self.ai_client.latency_connect_ms
        if self._metrics and self.ai_latency_ms > 0:
            self._metrics.ai_connect_latency.observe(
                self.ai_latency_ms / 1000.0
            )

    def _on_ai_audio(self, pcm16_bytes: bytes):
        """AI 产生音频块 → 帧缓冲区 → ai_to_fs_queue。"""
        self.is_ai_speaking = True
        self._frame_buf.push_pcm16(pcm16_bytes)

        for frame in self._frame_buf.pop_frames():
            try:
                self.ai_to_fs_queue.put_nowait(frame)
            except queue.Full:
                if self._metrics:
                    self._metrics.audio_drop_total.labels(
                        direction="out"
                    ).inc()
                try:
                    self.ai_to_fs_queue.get_nowait()
                    self.ai_to_fs_queue.put_nowait(frame)
                except queue.Empty:
                    pass

    def _on_ai_turn_done(self):
        """本轮结束，flush 帧缓冲区剩余数据（修复 [10]：用公开方法）。"""
        tail = self._frame_buf.flush()
        if tail:
            try:
                self.ai_to_fs_queue.put_nowait(tail)
            except queue.Full:
                pass
        logger.debug(f"[{self.uuid}] AI turn done")

    def _on_speech_started(self):
        if self.is_ai_speaking:
            self.barge_in()

    def _on_transcript(self, text: str):
        logger.info(f"[{self.uuid}] User: {text}")
        if self._metrics:
            self._metrics.transcripts_total.inc()

    def _on_ai_error(self, reason: str):
        logger.error(f"[{self.uuid}] AI error: {reason!r}")
        if self._metrics:
            self._metrics.ai_errors_total.labels(reason=reason).inc()
        if self.is_active:
            self.hangup(f"ai_error:{reason}")

    # ================================================================== #
    #  FIFO 降级模式：播放线程
    # ================================================================== #

    def _play_loop_fifo(self):
        """
        累积 AI 音频帧，批量写文件 + uuid_broadcast 播放。
        减少 ESL 调用频率，降低系统负载。
        """
        buf        = bytearray()
        last_data  = time.monotonic()
        last_flush = time.monotonic()

        while self.is_active:
            try:
                frame = self.ai_to_fs_queue.get(timeout=0.02)
                buf.extend(frame)
                last_data = time.monotonic()
            except queue.Empty:
                pass

            now         = time.monotonic()
            queue_empty = self.ai_to_fs_queue.empty()
            should_flush = (
                len(buf) >= FLUSH_MIN_BYTES
                or (buf and queue_empty and now - last_data  >= 0.08)
                or (buf and now - last_flush >= FLUSH_MAX_SEC)
            )

            if should_flush and buf:
                self._flush_to_fs(bytes(buf))
                buf.clear()
                last_flush = now
                if queue_empty:
                    self.is_ai_speaking = False

        if buf:
            self._flush_to_fs(bytes(buf))
        logger.info(f"[{self.uuid}] Play loop exited")

    def _flush_to_fs(self, pcma_data: bytes):
        """写临时文件并通过 uuid_broadcast 播放。"""
        esl = self._esl_ref() if self._esl_ref else None
        if not esl or not self._tmp_dir:
            return

        fname = os.path.join(
            self._tmp_dir,
            f"{int(time.monotonic() * 1_000_000)}.pcma",
        )
        try:
            with open(fname, "wb") as f:
                f.write(pcma_data)
            esl.send_bgapi_nowait(
                f"uuid_broadcast {self.uuid} {fname} aleg"
            )
            if self._metrics:
                self._metrics.audio_frames_out.inc()
        except Exception as e:
            logger.error(f"[{self.uuid}] flush_to_fs error: {e}")
            return

        self._cleanup_old_files()

    def _cleanup_old_files(self):
        if not self._tmp_dir or not os.path.exists(self._tmp_dir):
            return
        try:
            files = sorted(
                (f for f in os.listdir(self._tmp_dir)
                 if f.endswith(".pcma")),
                key=lambda f: os.path.getmtime(
                    os.path.join(self._tmp_dir, f)
                ),
            )
            for old in files[:-KEEP_AUDIO_FILES]:
                try:
                    os.remove(os.path.join(self._tmp_dir, old))
                except OSError:
                    pass
        except Exception:
            pass

    # ================================================================== #
    #  工具
    # ================================================================== #

    def _drain_audio(self):
        """清空音频队列和帧缓冲区（barge-in 时调用）。"""
        for q in (self.ai_to_fs_queue, self.fs_to_ai_queue):
            while not q.empty():
                try:
                    q.get_nowait()
                except queue.Empty:
                    break
        self._frame_buf.clear()

    def to_dict(self) -> dict:
        """序列化为 API 响应格式。"""
        return {
            "uuid":             self.uuid,
            "direction":        self.direction,
            "caller":           self.caller_number,
            "callee":           self.callee_number,
            "is_active":        self.is_active,
            "is_answered":      self.is_answered,
            "is_ai_speaking":   self.is_ai_speaking,
            "ai_connected":     (
                self.ai_client.connected if self.ai_client else False
            ),
            "audio_mode":       (
                "stream" if self.use_audio_stream else "fifo"
            ),
            "audio_in_bytes":   self.audio_in_bytes,
            "audio_out_bytes":  self.audio_out_bytes,
            "barge_in_count":   self.barge_in_count,
            "ai_latency_ms":    round(self.ai_latency_ms, 1),
            "duration_sec":     round(time.time() - self.created_at, 1),
        }
