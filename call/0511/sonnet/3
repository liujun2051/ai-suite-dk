## `ai_client.py`

```python
"""
ai_client.py  ─  MiniCPM-o WebSocket 客户端 v3.0

修复：
  [1] 移除错误的 _make_socket / sock= 参数，改为连接后设置 TCP_NODELAY
  [2] 发送队列化：_send_loop 串行发出，避免并发写 WebSocket
  [3] 连接状态机：DISCONNECTED / CONNECTING / READY / CLOSING
  [4] 首帧延迟计时（供 Prometheus 使用）
  [5] 所有回调异常隔离
"""

import asyncio
import base64
import json
import logging
import socket as _socket
import time
from enum import Enum, auto
from typing import Callable, Optional

import websockets
import websockets.exceptions

import config

logger = logging.getLogger("AIClient")

_SEND_TIMEOUT    = 5.0
_CONNECT_TIMEOUT = 10.0
_HANDSHAKE_TIMEOUT = 15.0
_SEND_QUEUE_SIZE = 200


class ClientState(Enum):
    DISCONNECTED = auto()
    CONNECTING   = auto()
    READY        = auto()
    CLOSING      = auto()


class AIClient:
    """
    封装与 MiniCPM-o 的 WebSocket 会话。

    线程模型：
      - 所有方法均为协程，运行在同一事件循环
      - send_audio / send_text 将消息放入 _send_queue
      - _send_loop 串行从队列取出并发送（WebSocket 不支持并发写）

    回调（在事件循环线程同步调用，必须快速返回）：
      on_audio_chunk(pcm16_bytes: bytes)
      on_turn_done()
      on_speech_started()
      on_transcript(text: str)
      on_error(reason: str)
      on_connected()
    """

    def __init__(self, session_id: str):
        self.session_id = session_id
        self.mode: str  = config.AI_MODE

        self._state      = ClientState.DISCONNECTED
        self._ws         = None
        self._send_queue: asyncio.Queue = asyncio.Queue(
            maxsize=_SEND_QUEUE_SIZE
        )

        self._recv_task: Optional[asyncio.Task] = None
        self._send_task: Optional[asyncio.Task] = None

        # 延迟测量
        self._connect_start:    float = 0.0
        self._first_audio_recv: float = 0.0

        # 回调
        self.on_audio_chunk:    Optional[Callable[[bytes], None]] = None
        self.on_turn_done:      Optional[Callable[[], None]]      = None
        self.on_speech_started: Optional[Callable[[], None]]      = None
        self.on_transcript:     Optional[Callable[[str], None]]   = None
        self.on_error:          Optional[Callable[[str], None]]   = None
        self.on_connected:      Optional[Callable[[], None]]      = None

    # ------------------------------------------------------------------ #
    #  属性
    # ------------------------------------------------------------------ #

    @property
    def connected(self) -> bool:
        return self._state == ClientState.READY

    @property
    def latency_connect_ms(self) -> float:
        """从开始连接到收到首帧音频的耗时（毫秒）。"""
        if self._first_audio_recv > 0 and self._connect_start > 0:
            return (self._first_audio_recv - self._connect_start) * 1000
        return -1.0

    # ------------------------------------------------------------------ #
    #  生命周期
    # ------------------------------------------------------------------ #

    async def connect(self) -> bool:
        """
        建立 WebSocket 连接并完成握手。
        修复：不传 sock= 参数，连接建立后再设置 TCP_NODELAY。
        """
        if self._state != ClientState.DISCONNECTED:
            logger.warning(
                f"[{self.session_id}] connect() in state {self._state}"
            )
            return False

        self._state         = ClientState.CONNECTING
        self._connect_start = time.monotonic()

        extra_headers = {}
        if self.mode == "cloud":
            extra_headers["Authorization"] = (
                f"Bearer {config.CLOUD_API_KEY}"
            )

        try:
            self._ws = await asyncio.wait_for(
                websockets.connect(
                    config.MINICPM_WS_URL,
                    extra_headers=extra_headers,
                    ping_interval=20,
                    ping_timeout=10,
                    max_size=16 * 1024 * 1024,
                    compression=None,   # 关闭压缩，降低 CPU 和延迟
                ),
                timeout=_CONNECT_TIMEOUT,
            )
        except asyncio.TimeoutError:
            logger.error(f"[{self.session_id}] AI connect timeout")
            self._state = ClientState.DISCONNECTED
            return False
        except Exception as e:
            logger.error(f"[{self.session_id}] AI connect failed: {e}")
            self._state = ClientState.DISCONNECTED
            return False

        # 连接建立后设置 TCP_NODELAY（修复：不在 connect 之前操作 socket）
        self._set_tcp_nodelay()

        # 协议握手
        try:
            await asyncio.wait_for(
                self._handshake(),
                timeout=_HANDSHAKE_TIMEOUT,
            )
        except asyncio.TimeoutError:
            logger.error(f"[{self.session_id}] AI handshake timeout")
            await self._ws.close()
            self._state = ClientState.DISCONNECTED
            return False
        except Exception as e:
            logger.error(f"[{self.session_id}] AI handshake failed: {e}")
            await self._ws.close()
            self._state = ClientState.DISCONNECTED
            return False

        # 启动后台任务
        self._recv_task = asyncio.create_task(
            self._recv_loop(),
            name=f"ai-recv-{self.session_id[:8]}",
        )
        self._send_task = asyncio.create_task(
            self._send_loop(),
            name=f"ai-send-{self.session_id[:8]}",
        )

        self._state = ClientState.READY
        elapsed = (time.monotonic() - self._connect_start) * 1000
        logger.info(
            f"[{self.session_id}] AI ready ({elapsed:.0f}ms)"
        )

        self._fire(self.on_connected)
        return True

    def _set_tcp_nodelay(self):
        """
        对已建立的 WebSocket 连接设置 TCP_NODELAY。
        修复：在连接建立后从 transport 获取 socket，不在连接前操作。
        """
        try:
            transport = self._ws.transport
            if transport is None:
                return
            sock = transport.get_extra_info("socket")
            if sock is None:
                return
            sock.setsockopt(
                _socket.IPPROTO_TCP,
                _socket.TCP_NODELAY,
                1,
            )
            sock.setsockopt(
                _socket.SOL_SOCKET,
                _socket.SO_KEEPALIVE,
                1,
            )
            logger.debug(f"[{self.session_id}] TCP_NODELAY set")
        except Exception as e:
            logger.debug(f"[{self.session_id}] TCP_NODELAY failed: {e}")

    async def close(self):
        """优雅关闭，幂等。"""
        if self._state == ClientState.CLOSING:
            return
        prev_state  = self._state
        self._state = ClientState.CLOSING

        # 向发送队列注入毒丸
        try:
            self._send_queue.put_nowait(None)
        except asyncio.QueueFull:
            pass

        for task in (self._send_task, self._recv_task):
            if task and not task.done():
                task.cancel()
                try:
                    await task
                except asyncio.CancelledError:
                    pass

        if self._ws:
            try:
                await asyncio.wait_for(self._ws.close(), timeout=2.0)
            except Exception:
                pass
            self._ws = None

        self._state = ClientState.DISCONNECTED
        logger.info(f"[{self.session_id}] AI client closed")

    # ------------------------------------------------------------------ #
    #  发送接口（入队，由 _send_loop 串行发出）
    # ------------------------------------------------------------------ #

    async def send_audio(self, pcm16_bytes: bytes):
        """发送用户音频（PCM16LE bytes）。非阻塞入队。"""
        if self._state != ClientState.READY or not pcm16_bytes:
            return

        if self.mode == "cloud":
            msg = json.dumps({
                "type":  "input_audio_buffer.append",
                "audio": base64.b64encode(pcm16_bytes).decode(),
            })
        else:
            msg = pcm16_bytes

        await self._enqueue(msg)

    async def send_text(self, text: str):
        """发送文本消息。"""
        if self._state != ClientState.READY:
            return
        if self.mode == "cloud":
            for msg in (
                json.dumps({
                    "type": "conversation.item.create",
                    "item": {
                        "type": "message",
                        "role": "user",
                        "content": [{"type": "input_text", "text": text}],
                    },
                }),
                json.dumps({"type": "response.create"}),
            ):
                await self._enqueue(msg)
        else:
            await self._enqueue(
                json.dumps({"type": "text_input", "text": text})
            )

    async def interrupt(self):
        """
        打断 AI 当前输出。
        高优先级：直接发送，不经过发送队列。
        """
        if self._state != ClientState.READY:
            return
        try:
            if self.mode == "cloud":
                payload = json.dumps({"type": "input_audio_buffer.clear"})
            else:
                payload = json.dumps({"type": "barge_in"})
            await asyncio.wait_for(
                self._ws.send(payload),
                timeout=_SEND_TIMEOUT,
            )
        except Exception as e:
            logger.error(f"[{self.session_id}] interrupt error: {e}")

    # ------------------------------------------------------------------ #
    #  内部：握手
    # ------------------------------------------------------------------ #

    async def _handshake(self):
        if self.mode == "cloud":
            await self._handshake_cloud()
        else:
            await self._handshake_local()

    async def _handshake_cloud(self):
        async for raw in self._ws:
            data = json.loads(raw)
            if data.get("type") == "session.created":
                break

        await self._ws.send(json.dumps({
            "type": "session.update",
            "session": {
                "instructions":        config.AI_SYSTEM_PROMPT,
                "voice":               config.AI_VOICE,
                "input_audio_format":  "pcm16",
                "output_audio_format": "pcm16",
                "turn_detection": {
                    "type":                "server_vad",
                    "threshold":           0.5,
                    "silence_duration_ms": 600,
                },
                "input_audio_transcription": {
                    "model":    "whisper-1",
                    "language": "zh",
                },
            },
        }))

        async for raw in self._ws:
            data = json.loads(raw)
            if data.get("type") == "session.updated":
                break

    async def _handshake_local(self):
        await self._ws.send(json.dumps({
            "type":        "init",
            "session_id":  self.session_id,
            "sample_rate": config.AI_SAMPLE_RATE,
            "channels":    1,
            "format":      "pcm_s16le",
        }))
        # 等待本地服务端确认
        async for raw in self._ws:
            if isinstance(raw, str):
                try:
                    data = json.loads(raw)
                    if data.get("type") in ("ready", "init_ok"):
                        break
                except json.JSONDecodeError:
                    pass
            # 超时由外层 wait_for 控制

    # ------------------------------------------------------------------ #
    #  内部：发送循环（串行，WebSocket 不支持并发写）
    # ------------------------------------------------------------------ #

    async def _send_loop(self):
        """
        从 _send_queue 串行取消息发送。
        串行是必须的：websockets 库不支持多个协程同时调用 ws.send()。
        """
        while True:
            try:
                msg = await self._send_queue.get()
            except asyncio.CancelledError:
                break

            if msg is None:   # 毒丸：退出信号
                break

            try:
                await asyncio.wait_for(
                    self._ws.send(msg),
                    timeout=_SEND_TIMEOUT,
                )
            except asyncio.TimeoutError:
                logger.warning(
                    f"[{self.session_id}] send timeout, dropping"
                )
            except websockets.exceptions.ConnectionClosed:
                logger.warning(
                    f"[{self.session_id}] WS closed during send"
                )
                self._state = ClientState.DISCONNECTED
                break
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"[{self.session_id}] send error: {e}")

    # ------------------------------------------------------------------ #
    #  内部：接收循环
    # ------------------------------------------------------------------ #

    async def _recv_loop(self):
        try:
            async for msg in self._ws:
                if self._state == ClientState.CLOSING:
                    break
                if isinstance(msg, bytes):
                    self._on_binary(msg)
                else:
                    self._dispatch_json(msg)

        except asyncio.CancelledError:
            pass
        except websockets.exceptions.ConnectionClosed as e:
            logger.warning(
                f"[{self.session_id}] AI WS closed: "
                f"code={e.code} reason={e.reason!r}"
            )
        except Exception as e:
            logger.exception(
                f"[{self.session_id}] recv loop error: {e}"
            )
        finally:
            if self._state == ClientState.READY:
                self._state = ClientState.DISCONNECTED
                self._fire(self.on_error, "connection_lost")

    def _on_binary(self, data: bytes):
        """本地模式：收到二进制 PCM16 音频。"""
        self._record_first_audio()
        self._fire(self.on_audio_chunk, data)

    def _dispatch_json(self, raw: str):
        """解析并分发 JSON 消息。"""
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            logger.warning(
                f"[{self.session_id}] invalid JSON: {raw[:80]!r}"
            )
            return

        t = data.get("type", "")

        if t == "response.output_audio.delta":
            chunk = base64.b64decode(data.get("delta", ""))
            if chunk:
                self._record_first_audio()
                self._fire(self.on_audio_chunk, chunk)

        elif t == "response.output_audio.done":
            self._fire(self.on_turn_done)

        elif t == "input_audio_buffer.speech_started":
            self._fire(self.on_speech_started)

        elif t == "conversation.item.input_audio_transcription.completed":
            text = data.get("transcript", "").strip()
            if text:
                self._fire(self.on_transcript, text)

        elif t == "error":
            err = data.get("error", {})
            logger.error(f"[{self.session_id}] AI error: {err}")
            self._fire(self.on_error, str(err))

    # ------------------------------------------------------------------ #
    #  内部：工具
    # ------------------------------------------------------------------ #

    def _record_first_audio(self):
        """记录首帧音频时间（只记录一次）。"""
        if self._first_audio_recv == 0:
            self._first_audio_recv = time.monotonic()
            elapsed = (
                self._first_audio_recv - self._connect_start
            ) * 1000
            logger.info(
                f"[{self.session_id}] First AI audio: {elapsed:.0f}ms"
            )

    async def _enqueue(self, msg):
        """入队，队满时丢弃最旧消息（保实时性）。"""
        try:
            self._send_queue.put_nowait(msg)
        except asyncio.QueueFull:
            try:
                self._send_queue.get_nowait()
                self._send_queue.put_nowait(msg)
            except (asyncio.QueueEmpty, asyncio.QueueFull):
                pass

    def _fire(self, cb: Optional[Callable], *args):
        """安全调用回调，异常隔离，不影响调用方。"""
        if cb is None:
            return
        try:
            cb(*args)
        except Exception as e:
            logger.exception(
                f"[{self.session_id}] callback {cb.__name__} error: {e}"
            )
