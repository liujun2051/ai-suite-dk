"""
audio.py  ─  音频格式转换与帧缓冲 v3.0

常量：
  FS_RATE    = 8 000 Hz   G.711a（FreeSWITCH）
  AI_RATE    = 16 000 Hz  PCM16LE（AI 模型）
  FRAME_MS   = 20 ms      标准帧时长
  FRAME_PCMA = 160 B      20ms G.711a@8kHz（1 byte/sample）
"""

import logging
from typing import List

import numpy as np

from audio_utils import pcma_to_pcm, pcm_to_pcma, RESAMPLE_FUNC

logger = logging.getLogger("Audio")

# ── 采样率与帧大小常量 ───────────────────────────────────────────────────
FS_RATE      = 8_000
AI_RATE      = 16_000
FRAME_MS     = 20
FRAME_PCMA   = FS_RATE  * FRAME_MS // 1000 * 1    # 160 bytes
FRAME_PCM8K  = FS_RATE  * FRAME_MS // 1000 * 2    # 320 bytes
FRAME_PCM16K = AI_RATE  * FRAME_MS // 1000 * 2    # 640 bytes


class AudioConverter:
    """
    FreeSWITCH <-> AI 音频格式转换。
    无状态，线程安全，可在任意线程调用。
    """

    @staticmethod
    def fs_to_ai(pcma_bytes: bytes) -> bytes:
        """
        G.711a 8kHz -> PCM16LE 16kHz。

        Args:
            pcma_bytes: G.711a 编码字节（任意长度）
        Returns:
            PCM16LE 字节串（适合直接发给 AI）
        """
        if not pcma_bytes:
            return b""
        pcm_8k  = pcma_to_pcm(pcma_bytes)
        pcm_16k = RESAMPLE_FUNC(pcm_8k, FS_RATE, AI_RATE)
        return pcm_16k.astype(np.int16).tobytes()

    @staticmethod
    def ai_to_fs(pcm16_bytes: bytes) -> bytes:
        """
        PCM16LE 16kHz -> G.711a 8kHz。

        Args:
            pcm16_bytes: PCM16LE 字节串（任意长度）
        Returns:
            G.711a 编码字节
        """
        if not pcm16_bytes:
            return b""
        pcm_16k = np.frombuffer(pcm16_bytes, dtype=np.int16)
        pcm_8k  = RESAMPLE_FUNC(pcm_16k, AI_RATE, FS_RATE).astype(np.int16)
        return pcm_to_pcma(pcm_8k)


class AudioFrameBuffer:
    """
    将 AI 返回的变长 PCM16LE 音频块切割为标准 20ms PCMA 帧。

    使用方式（每个 session 独立实例，非线程安全）：
        buf = AudioFrameBuffer()
        buf.push_pcm16(chunk)        # AI 回调中调用
        frames = buf.pop_frames()    # 取出所有完整的 20ms 帧
        tail = buf.flush()           # turn_done 时取出剩余数据
        buf.clear()                  # barge-in 时清空
    """

    def __init__(self):
        self._raw = bytearray()

    def push_pcm16(self, pcm16_bytes: bytes):
        """接收 PCM16LE，转换为 PCMA 后追加到内部缓冲区。"""
        if not pcm16_bytes:
            return
        pcma = AudioConverter.ai_to_fs(pcm16_bytes)
        self._raw.extend(pcma)

    def pop_frames(self) -> List[bytes]:
        """
        弹出所有完整的 20ms PCMA 帧（每帧 160 字节）。
        剩余不足一帧的数据留在缓冲区中。
        """
        frames = []
        while len(self._raw) >= FRAME_PCMA:
            frames.append(bytes(self._raw[:FRAME_PCMA]))
            del self._raw[:FRAME_PCMA]
        return frames

    def flush(self) -> bytes:
        """
        取出缓冲区中全部剩余数据（不足一帧的尾部）并清空。
        在 AI 本轮回复结束（turn_done）时调用，确保尾部不丢失。
        """
        remaining = bytes(self._raw)
        self._raw.clear()
        return remaining

    def clear(self):
        """清空缓冲区（barge-in 时调用）。"""
        self._raw.clear()

    def __len__(self) -> int:
        return len(self._raw)
