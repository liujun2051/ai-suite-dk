## `main.py` 更新版（集成所有模块）

```python
"""
main.py  ─  网关入口 v3.0

新增：
  - AudioStreamServer（mod_audio_stream 低延迟模式）
  - GatewayMetrics（Prometheus 监控）
  - FIFO 自动降级
"""

import asyncio
import logging
import os
import threading
import time
from contextlib import asynccontextmanager
from typing import Dict, List, Optional

import uvicorn

import config
from esl import ESLConnection
from session import CallSession, AudioStreamServer
from metrics import GatewayMetrics
from api import api_app, init as api_init

logger = logging.getLogger("Main")

ALLOWED_CONTEXTS = frozenset({"public", "default"})


# ======================================================================
#  会话管理器
# ======================================================================

class SessionManager:
    def __init__(self):
        self.sessions: Dict[str, CallSession] = {}
        self._lock = threading.RLock()

    def create(self, uuid: str, direction: str,
               caller: str, callee: str) -> CallSession:
        with self._lock:
            if uuid in self.sessions:
                return self.sessions[uuid]
            s = CallSession(
                uuid=uuid, direction=direction,
                caller_number=caller, callee_number=callee,
            )
            self.sessions[uuid] = s
            return s

    def get(self, uuid: str) -> Optional[CallSession]:
        with self._lock:
            return self.sessions.get(uuid)

    def remove(self, uuid: str):
        with self._lock:
            self.sessions.pop(uuid, None)

    def list_active(self) -> List[dict]:
        with self._lock:
            return [s.to_dict() for s in self.sessions.values()]


# ======================================================================
#  ESL 事件处理
# ======================================================================

class GatewayEventHandler:
    def __init__(self,
                 mgr:          SessionManager,
                 esl:          ESLConnection,
                 loop:         asyncio.AbstractEventLoop,
                 metrics:      GatewayMetrics,
                 audio_server: Optional[AudioStreamServer]):
        self._mgr          = mgr
        self._esl          = esl
        self._loop         = loop
        self._metrics      = metrics
        self._audio_server = audio_server

    def on_channel_create(self, event: dict):
        h         = event["headers"]
        call_uuid = h.get("Unique-ID", "")
        direction = h.get("Call-Direction", "unknown")
        caller    = h.get("Caller-Caller-ID-Number", "unknown")
        callee    = h.get("Caller-Destination-Number", "unknown")
        context   = h.get("Caller-Context", "")

        if context not in ALLOWED_CONTEXTS:
            return

        self._mgr.create(call_uuid, direction, caller, callee)
        logger.info(
            f"[ESL] CREATE {call_uuid} ({direction}) {caller} -> {callee}"
        )

    def on_channel_answer(self, event: dict):
        h         = event["headers"]
        call_uuid = h.get("Unique-ID", "")
        session   = self._mgr.get(call_uuid)
        if not session:
            return

        session.on_answered()

        if self._audio_server is not None:
            # mod_audio_stream 模式：
            # FS dialplan 需要在 answer 之后执行 audio_stream 应用
            # 本程序只需注册 session，等待 WS 连接到来
            session.start(
                loop=self._loop,
                esl_conn=self._esl,
                metrics=self._metrics,
                audio_server=self._audio_server,
            )
        else:
            # FIFO 降级模式
            fifo_path = f"/tmp/minicpm_{call_uuid}.pcma"
            try:
                os.mkfifo(fifo_path)
            except FileExistsError:
                pass
            except OSError as e:
                logger.error(f"[{call_uuid}] mkfifo failed: {e}")
                return

            session._fifo_path = fifo_path
            session.start(
                loop=self._loop,
                esl_conn=self._esl,
                metrics=self._metrics,
                audio_server=None,
            )
            try:
                self._esl.send_bgapi_nowait(
                    f"uuid_record {call_uuid} start {fifo_path} 1800"
                )
            except Exception as e:
                logger.error(f"[{call_uuid}] uuid_record failed: {e}")
                return
            session.start_fifo()

        self._metrics.calls_total.labels(
            direction=session.direction, result="started"
        ).inc()
        logger.info(f"[ESL] ANSWER {call_uuid}")

    def on_channel_hangup(self, event: dict):
        h         = event["headers"]
        call_uuid = h.get("Unique-ID", "")
        cause     = h.get("Hangup-Cause", "UNKNOWN")
        session   = self._mgr.get(call_uuid)
        if session:
            if self._audio_server:
                self._audio_server.unregister_session(call_uuid)
            session.hangup(cause)
            self._mgr.remove(call_uuid)
            self._metrics.calls_total.labels(
                direction=session.direction, result="ended"
            ).inc()
        logger.info(f"[ESL] HANGUP {call_uuid} cause={cause}")

    def on_dtmf(self, event: dict):
        h         = event["headers"]
        call_uuid = h.get("Unique-ID", "")
        digit     = h.get("DTMF-Digit", "")
        session   = self._mgr.get(call_uuid)
        if session and digit:
            session.on_dtmf(digit)


# ======================================================================
#  应用启动
# ======================================================================

def build_app():
    @asynccontextmanager
    async def lifespan(app):
        loop = asyncio.get_running_loop()

        logging.basicConfig(
            level=getattr(logging, config.LOG_LEVEL, logging.INFO),
            format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
            datefmt="%H:%M:%S",
        )

        # Prometheus
        metrics = GatewayMetrics()
        metrics.start_http_server(
            getattr(config, "METRICS_PORT", 9090)
        )

        # AudioStreamServer（mod_audio_stream 模式）
        use_audio_stream = getattr(config, "USE_AUDIO_STREAM", True)
        audio_server: Optional[AudioStreamServer] = None
        if use_audio_stream:
            audio_server = AudioStreamServer(
                host=getattr(config, "STREAM_WS_HOST", "0.0.0.0"),
                port=getattr(config, "STREAM_WS_PORT", 8081),
            )
            await audio_server.start()

        # ESL
        esl = ESLConnection(
            config.FS_HOST, config.FS_ESL_PORT, config.FS_ESL_PASS
        )
        if not esl.connect():
            raise RuntimeError("ESL connection failed")

        metrics.esl_connected.set(1)

        mgr     = SessionManager()
        handler = GatewayEventHandler(
            mgr, esl, loop, metrics, audio_server
        )

        esl.on("CHANNEL_CREATE",  handler.on_channel_create)
        esl.on("CHANNEL_ANSWER",  handler.on_channel_answer)
        esl.on("CHANNEL_HANGUP",  handler.on_channel_hangup)
        esl.on("DTMF",            handler.on_dtmf)

        esl.subscribe(
            "CHANNEL_CREATE", "CHANNEL_ANSWER",
            "CHANNEL_HANGUP", "DTMF", "BACKGROUND_JOB",
        )
        esl.start()

        api_init(mgr, esl, loop, metrics)

        logger.info("=" * 52)
        logger.info("  MiniCPM-o Gateway v3.0")
        logger.info(f"  Mode    : {'mod_audio_stream' if use_audio_stream else 'FIFO'}")
        logger.info(f"  AI      : {config.AI_MODE} @ {config.MINICPM_WS_URL}")
        logger.info(f"  ESL     : {config.FS_HOST}:{config.FS_ESL_PORT}")
        logger.info(f"  API     : http://0.0.0.0:{config.API_PORT}")
        if use_audio_stream:
            logger.info(f"  Stream  : ws://0.0.0.0:{config.STREAM_WS_PORT}")
        logger.info(f"  Metrics : http://0.0.0.0:{getattr(config,'METRICS_PORT',9090)}/metrics")
        logger.info("=" * 52)

        yield

        # 关闭
        logger.info("Shutting down...")
        with mgr._lock:
            sessions = list(mgr.sessions.values())
        for s in sessions:
            s.hangup("server_shutdown")
        if audio_server:
            await audio_server.stop()
        esl.stop()
        metrics.esl_connected.set(0)
        logger.info("Shutdown complete")

    api_app.router.lifespan_context = lifespan
    return api_app


def main():
    app = build_app()
    uvicorn.run(
        app,
        host="0.0.0.0",
        port=getattr(config, "API_PORT", 8080),
        log_level="warning",
    )


if __name__ == "__main__":
    main()
```

