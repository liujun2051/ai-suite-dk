            self._noop()
            return

        # ── 通话指标 ────────────────────────────────────────────────────

        self.active_calls = Gauge(
            "active_calls",
            "当前活跃通话数",
            namespace=self.NAMESPACE,
        )

        self.calls_total = Counter(
            "calls_total",
            "通话总数",
            ["direction", "result"],   # direction: inbound/outbound, result: success/failed
            namespace=self.NAMESPACE,
        )

        self.call_duration = Histogram(
            "call_duration_seconds",
            "通话时长分布",
            buckets=[10, 30, 60, 120, 300, 600, 1800],
            namespace=self.NAMESPACE,
        )

        # ── AI 指标 ─────────────────────────────────────────────────────

        self.ai_connect_latency = Histogram(
            "ai_connect_latency_seconds",
            "AI WebSocket 连接到首帧音频的延迟",
            buckets=[0.1, 0.2, 0.3, 0.5, 0.8, 1.0, 2.0, 5.0],
            namespace=self.NAMESPACE,
        )

        self.ai_errors_total = Counter(
            "ai_errors_total",
            "AI 连接错误总数",
            ["reason"],
            namespace=self.NAMESPACE,
        )

        # ── 音频指标 ────────────────────────────────────────────────────

        self.audio_frames_in = Counter(
            "audio_frames_in_total",
            "从 FS 收到的音频帧总数",
            namespace=self.NAMESPACE,
        )

        self.audio_frames_out = Counter(
            "audio_frames_out_total",
            "发送给 FS 的音频帧总数",
            namespace=self.NAMESPACE,
        )

        self.audio_drop_total = Counter(
            "audio_drop_total",
            "因队列满丢弃的音频帧数",
            ["direction"],   # in / out
            namespace=self.NAMESPACE,
        )

        self.barge_in_total = Counter(
            "barge_in_total",
            "用户打断次数",
            namespace=self.NAMESPACE,
        )

        self.transcripts_total = Counter(
            "transcripts_total",
            "语音识别结果总数",
            namespace=self.NAMESPACE,
        )

        # ── ESL 指标 ─────────────────────────────────────────────────────

        self.esl_connected = Gauge(
            "esl_connected",
            "ESL 连接状态（1=已连接，0=断开）",
            namespace=self.NAMESPACE,
        )

        self.esl_reconnects_total = Counter(
            "esl_reconnects_total",
            "ESL 重连次数",
            namespace=self.NAMESPACE,
        )

        # ── 系统信息 ────────────────────────────────────────────────────

        self.build_info = Info(
            "build",
            "网关版本信息",
            namespace=self.NAMESPACE,
        )
        self.build_info.info({
            "version": "3.0",
            "audio_mode": "mod_audio_stream",
        })

        logger.info("Prometheus metrics initialized")

    def _noop(self):
        """prometheus_client 未安装时，所有指标替换为空操作。"""
        _n = _NoOpMetric()
        self.active_calls        = _n
        self.calls_total         = _n
        self.call_duration       = _n
        self.ai_connect_latency  = _n
        self.ai_errors_total     = _n
        self.audio_frames_in     = _n
        self.audio_frames_out    = _n
        self.audio_drop_total    = _n
        self.barge_in_total      = _n
        self.transcripts_total   = _n
        self.esl_connected       = _n
        self.esl_reconnects_total = _n
        self.build_info          = _n

    def start_http_server(self, port: int = 9090):
        """
        启动 Prometheus metrics HTTP 服务器。
        访问 http://host:9090/metrics 即可获取指标。
        """
        if not _PROMETHEUS_AVAILABLE:
            return
        try:
            _start_http(port)
            logger.info(f"Prometheus metrics server started on :{port}")
        except Exception as e:
            logger.error(f"Failed to start metrics server: {e}")
