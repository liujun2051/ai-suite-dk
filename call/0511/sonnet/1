class GatewayMetrics:
    """
    网关监控指标集合。

    指标命名遵循 Prometheus 规范：
      {namespace}_{subsystem}_{name}_{unit}
      minicpm_call_duration_seconds
    """

    NAMESPACE = "minicpm"

