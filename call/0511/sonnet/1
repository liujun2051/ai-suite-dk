## `ai_client.py` 完整版

```python
"""
ai_client.py  ─  MiniCPM-o WebSocket 客户端 v3.0

改进点：
  - 发送队列化：send_audio 不直接 await ws.send，
    而是入队，由独立发送协程串行发出，避免并发写 WebSocket
  - 连接状态机：DISCONNECTED / CONNECTING / READY / CLOSING
  - 指数退避重连（可选，由外部控制）
  - 首帧延迟计时（用于 Prometheus）
  - 所有回调异常隔离，不影响接收循环
"""

import asyncio
import base64
import json
import logging
import time
from enum import Enum, auto
from typing import Callable, Optional

import websockets
import websockets.exceptions

import config

logger = logging.getLogger("AIClient")


class ClientState(Enum):
    DISCONNECTED = auto()
    CONNECTING   = auto()
    READY        = auto()
    CLOSING      = auto()


class AIClient:
    """
    封装与 MiniCPM-o 的 WebSocket 会话。

    线程模型：
      - 所有方法均为协程，运行在同一事件循环
      - send_audio / send_text 将数据放入 _send_queue
      - _send_loop 协程串行从队列取出并发送，避免并发写 WebSocket

    回调（在事件循环线程同步调用，必须快速返回）：
      on_audio_chunk(pcm16_bytes: bytes)   收到 AI 音频块
      on_turn_done()                        AI 本轮回复结束
      on_speech_started()                   VAD 检测到用户说话
      on_transcript(text: str)              语音识别结果
      on_error(reason: str)                 不可恢复错误
      on_connected()                        连接就绪（初始化完成后）
    """

    _SEND_TIMEOUT    = 5.0    # 单条消息发送超时（秒）
    _CONNECT_TIMEOUT = 10.0   # 建立连接超时（秒）
    _SEND_QUEUE_SIZE = 200    # 发送队列最大深度

    def __init__(self, session_id: str):
        self.session_id  = session_id
        self.mode: str   = config.AI_MODE

        self._state      = ClientState.DISCONNECTED
        self._ws         = None
        self._send_queue: asyncio.Queue = asyncio.Queue(
            maxsize=self._SEND_QUEUE_SIZE
        )

        # 运行中的后台任务
        self._recv_task: Optional[asyncio.Task] = None
        self._send_task: Optional[asyncio.Task] = None

        # 延迟测量
        self._connect_start:    float = 0.0
        self._first_audio_sent: float = 0.0
        self._first_audio_recv: float = 0.0

        # 回调
        self.on_audio_chunk:    Optional[Callable[[bytes], None]] = None
        self.on_turn_done:      Optional[Callable[[], None]]      = None
        self.on_speech_started: Optional[Callable[[], None]]      = None
        self.on_transcript:     Optional[Callable[[str], None]]   = None
        self.on_error:          Optional[Callable[[str], None]]   = None
        self.on_connected:      Optional[Callable[[], None]]      = None

    # ------------------------------------------------------------------ #
    #  属性
    # ------------------------------------------------------------------ #

    @property
    def connected(self) -> bool:
        return self._state == ClientState.READY

    @property
    def latency_connect_ms(self) -> float:
        """从开始连接到 READY 的耗时（毫秒）。"""
        if self._first_audio_recv > 0 and self._connect_start > 0:
            return (self._first_audio_recv - self._connect_start) * 1000
        return -1.0

    # ------------------------------------------------------------------ #
    #  生命周期
    # ------------------------------------------------------------------ #

    async def connect(self) -> bool:
        """
        建立 WebSocket 连接并完成初始化握手。
        成功后启动接收/发送后台任务，触发 on_connected 回调。
        """
        if self._state != ClientState.DISCONNECTED:
            logger.warning(f"[{self.session_id}] connect() called in state {self._state}")
            return False

        self._state        = ClientState.CONNECTING
        self._connect_start = time.monotonic()

        extra_headers = {}
        if self.mode == "cloud":
            extra_headers["Authorization"] = f"Bearer {config.CLOUD_API_KEY}"

        try:
            self._ws = await asyncio.wait_for(
                websockets.connect(
                    config.MINICPM_WS_URL,
                    extra_headers=extra_headers,
                    ping_interval=20,
                    ping_timeout=10,
                    max_size=16 * 1024 * 1024,   # 16MB，防止大音频包截断
                    # 关键：关闭 Nagle 算法，降低 TCP 层延迟
                    sock=await self._make_socket(),
                ),
                timeout=self._CONNECT_TIMEOUT,
            )
        except asyncio.TimeoutError:
            logger.error(f"[{self.session_id}] AI connect timeout")
            self._state = ClientState.DISCONNECTED
            return False
        except Exception as e:
            logger.error(f"[{self.session_id}] AI connect failed: {e}")
            self._state = ClientState.DISCONNECTED
            return False

        # 完成协议层握手（session.update 等）
        try:
            await asyncio.wait_for(
                self._handshake(),
                timeout=15.0,
            )
        except asyncio.TimeoutError:
            logger.error(f"[{self.session_id}] AI handshake timeout")
            await self._ws.close()
            self._state = ClientState.DISCONNECTED
            return False
        except Exception as e:
            logger.error(f"[{self.session_id}] AI handshake failed: {e}")
            await self._ws.close()
            self._state = ClientState.DISCONNECTED
            return False

        # 启动后台任务
        self._recv_task = asyncio.create_task(
            self._recv_loop(),
            name=f"ai-recv-{self.session_id[:8]}",
        )
        self._send_task = asyncio.create_task(
            self._send_loop(),
            name=f"ai-send-{self.session_id[:8]}",
        )

        self._state = ClientState.READY
        logger.info(
            f"[{self.session_id}] AI ready "
            f"(connect={( time.monotonic()-self._connect_start)*1000:.0f}ms)"
        )

        if self.on_connected:
            self._fire(self.on_connected)

        return True

    async def close(self):
        """优雅关闭，幂等。"""
        if self._state == ClientState.CLOSING:
            return
        self._state = ClientState.CLOSING

        # 停止发送任务
        if self._send_task and not self._send_task.done():
            self._send_task.cancel()
            try:
                await self._send_task
            except asyncio.CancelledError:
                pass

        # 停止接收任务
        if self._recv_task and not self._recv_task.done():
            self._recv_task.cancel()
            try:
                await self._recv_task
            except asyncio.CancelledError:
                pass

        # 关闭 WebSocket
        if self._ws:
            try:
                await asyncio.wait_for(self._ws.close(), timeout=2.0)
            except Exception:
                pass
            self._ws = None

        self._state = ClientState.DISCONNECTED
        logger.info(f"[{self.session_id}] AI client closed")

    # ------------------------------------------------------------------ #
    #  发送接口（将数据入队，由 _send_loop 串行发出）
    # ------------------------------------------------------------------ #

    async def send_audio(self, pcm16_bytes: bytes):
        """
        发送用户音频（PCM16LE）。
        入队操作，非阻塞。队满时丢弃最旧的包（保实时性）。
        """
        if self._state != ClientState.READY or not pcm16_bytes:
            return

        if self._first_audio_sent == 0:
            self._first_audio_sent = time.monotonic()

        if self.mode == "cloud":
            msg = json.dumps({
                "type":  "input_audio_buffer.append",
                "audio": base64.b64encode(pcm16_bytes).decode(),
            })
        else:
            msg = pcm16_bytes   # 本地模式：二进制

        await self._enqueue(msg)

    async def send_text(self, text: str):
        """发送文本消息。"""
        if self._state != ClientState.READY:
            return
        if self.mode == "cloud":
            msgs = [
                json.dumps({
                    "type": "conversation.item.create",
                    "item": {
                        "type": "message",
                        "role": "user",
                        "content": [{"type": "input_text", "text": text}],
                    },
                }),
                json.dumps({"type": "response.create"}),
            ]
            for m in msgs:
                await self._enqueue(m)
        else:
            await self._enqueue(
                json.dumps({"type": "text_input", "text": text})
            )

    async def interrupt(self):
        """打断 AI 当前输出。高优先级，直接发送不经过队列。"""
        if self._state != ClientState.READY:
            return
        try:
            if self.mode == "cloud":
                payload = json.dumps({"type": "input_audio_buffer.clear"})
            else:
                payload = json.dumps({"type": "barge_in"})
            await asyncio.wait_for(
                self._ws.send(payload),
                timeout=self._SEND_TIMEOUT,
            )
        except Exception as e:
            logger.error(f"[{self.session_id}] interrupt error: {e}")

    # ------------------------------------------------------------------ #
    #  内部：socket 低延迟配置
    # ------------------------------------------------------------------ #

    async def _make_socket(self):
        """
        创建关闭 Nagle 算法的 TCP socket。
        TCP_NODELAY 对于实时音频流至关重要：
          默认开启 Nagle 时，小包会等待 40ms 再发送（Nagle delay）。
          关闭后，每帧音频立即发出，减少 20~40ms 延迟。
        """
        import socket as _socket
        sock = _socket.socket(_socket.AF_INET, _socket.SOCK_STREAM)
        sock.setsockopt(_socket.IPPROTO_TCP, _socket.TCP_NODELAY, 1)
        sock.setsockopt(_socket.SOL_SOCKET,  _socket.SO_KEEPALIVE, 1)

        # 解析目标地址
        from urllib.parse import urlparse
        parsed = urlparse(config.MINICPM_WS_URL)
        host   = parsed.hostname
        port   = parsed.port or (443 if parsed.scheme == "wss" else 80)

        loop = asyncio.get_running_loop()
        await loop.sock_connect(sock, (host, port))
        return sock

    # ------------------------------------------------------------------ #
    #  内部：握手
    # ------------------------------------------------------------------ #

    async def _handshake(self):
        if self.mode == "cloud":
            await self._handshake_cloud()
        else:
            await self._handshake_local()

    async def _handshake_cloud(self):
        # 等待 session.created
        async for raw in self._ws:
            data = json.loads(raw)
            if data.get("type") == "session.created":
                logger.debug(f"[{self.session_id}] session.created received")
                break

        # 发送配置
        await self._ws.send(json.dumps({
            "type": "session.update",
            "session": {
                "instructions":        config.AI_SYSTEM_PROMPT,
                "voice":               config.AI_VOICE,
                "input_audio_format":  "pcm16",
                "output_audio_format": "pcm16",
                "turn_detection": {
                    "type":                "server_vad",
                    "threshold":           0.5,
                    "silence_duration_ms": 600,   # 更短静音检测，降低响应延迟
                },
                "input_audio_transcription": {
                    "model":    "whisper-1",
                    "language": "zh",
                },
            },
        }))

        # 等待 session.updated
        async for raw in self._ws:
            data = json.loads(raw)
            if data.get("type") == "session.updated":
                logger.debug(f"[{self.session_id}] session.updated received")
                break

    async def _handshake_local(self):
        await self._ws.send(json.dumps({
            "type":        "init",
            "session_id":  self.session_id,
            "sample_rate": config.AI_SAMPLE_RATE,
            "channels":    1,
            "format":      "pcm_s16le",
        }))
        # 本地模式：等待 ready 确认
        async for raw in self._ws:
            if isinstance(raw, str):
                data = json.loads(raw)
                if data.get("type") in ("ready", "init_ok"):
                    break
            # 超时由外层 wait_for 控制

    # ------------------------------------------------------------------ #
    #  内部：发送循环（串行，避免并发写 WebSocket）
    # ------------------------------------------------------------------ #

    async def _send_loop(self):
        """
        从 _send_queue 取消息串行发送。
        串行发送是 WebSocket 协议的要求：
          websockets 库的 ws.send() 不是线程/协程安全的并发写，
          多个协程同时 send 会导致帧交错或断连。
        """
        while True:
            try:
                msg = await self._send_queue.get()
            except asyncio.CancelledError:
                break

            if msg is None:   # 毒丸，退出信号
                break

            try:
                await asyncio.wait_for(
                    self._ws.send(msg),
                    timeout=self._SEND_TIMEOUT,
                )
            except asyncio.TimeoutError:
                logger.warning(f"[{self.session_id}] send timeout, dropping message")
            except websockets.exceptions.ConnectionClosed:
                logger.warning(f"[{self.session_id}] WS closed during send")
                self._state = ClientState.DISCONNECTED
                break
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"[{self.session_id}] send error: {e}")

    # ------------------------------------------------------------------ #
    #  内部：接收循环
    # ------------------------------------------------------------------ #

    async def _recv_loop(self):
        try:
            async for msg in self._ws:
                if self._state == ClientState.CLOSING:
                    break
                if isinstance(msg, bytes):
                    # 本地模式：二进制 PCM16 音频
                    if self._first_audio_recv == 0:
                        self._first_audio_recv = time.monotonic()
                        elapsed = (self._first_audio_recv - self._connect_start) * 1000
                        logger.info(
                            f"[{self.session_id}] First AI audio received "
                            f"({elapsed:.0f}ms from connect)"
                        )
                    self._fire(self.on_audio_chunk, msg)
                else:
                    self._dispatch_json(msg)

        except asyncio.CancelledError:
            pass
        except websockets.exceptions.ConnectionClosed as e:
            logger.warning(
                f"[{self.session_id}] AI WS closed: "
                f"code={e.code} reason={e.reason!r}"
            )
        except Exception as e:
            logger.exception(f"[{self.session_id}] recv loop error: {e}")
        finally:
            if self._state == ClientState.READY:
                self._state = ClientState.DISCONNECTED
                self._fire(self.on_error, "connection_lost")

    # ------------------------------------------------------------------ #
    #  内部：JSON 消息分发
    # ------------------------------------------------------------------ #

    def _dispatch_json(self, raw: str):
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            logger.warning(f"[{self.session_id}] invalid JSON: {raw[:80]!r}")
            return

        t = data.get("type", "")

        if t == "response.output_audio.delta":
            chunk = base64.b64decode(data.get("delta", ""))
            if chunk:
                if self._first_audio_recv == 0:
                    self._first_audio_recv = time.monotonic()
                    elapsed = (self._first_audio_recv - self._connect_start) * 1000
                    logger.info(
                        f"[{self.session_id}] First AI audio delta "
                        f"({elapsed:.0f}ms from connect)"
                    )
                self._fire(self.on_audio_chunk, chunk)

        elif t == "response.output_audio.done":
            self._fire(self.on_turn_done)

        elif t == "input_audio_buffer.speech_started":
            self._fire(self.on_speech_started)

        elif t == "conversation.item.input_audio_transcription.completed":
            text = data.get("transcript", "").strip()
            if text:
                self._fire(self.on_transcript, text)

        elif t == "error":
            err = data.get("error", {})
            logger.error(f"[{self.session_id}] AI protocol error: {err}")
            self._fire(self.on_error, str(err))

        # 其余消息类型（response.created 等）静默忽略

    # ------------------------------------------------------------------ #
    #  内部：工具
    # ------------------------------------------------------------------ #

    async def _enqueue(self, msg):
        """入队，队满时丢弃最旧的消息。"""
        try:
            self._send_queue.put_nowait(msg)
        except asyncio.QueueFull:
            try:
                self._send_queue.get_nowait()   # 丢弃最旧
                self._send_queue.put_nowait(msg)
            except asyncio.QueueEmpty:
                pass

    def _fire(self, cb: Optional[Callable], *args):
        """安全调用回调，异常隔离。"""
        if cb is None:
            return
        try:
            cb(*args)
        except Exception as e:
            logger.exception(
                f"[{self.session_id}] callback {cb.__name__} error: {e}"
            )
```

