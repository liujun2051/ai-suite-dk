<!-- /etc/freeswitch/dialplan/default/02_pipecat_personaplex.xml -->
<?xml version="1.0" encoding="utf-8"?>
<include>
  <extension name="pipecat_personaplex">
    <condition field="destination_number" expression="^(8889)$">
      <!-- 应答呼叫 -->
      <action application="answer"/>
      
      <!-- 设置音频参数：16kHz 单声道 -->
      <action application="set" data="sip_secure_media=false"/>
      <action application="set" data="RTP_SAMPLE_RATE=16000"/>
      <action application="set" data="RTP_TOS=0x68"/>
      
      <!-- 桥接到 Pipecat WebSocket 服务 -->
      <action application="bridge" data="ws://localhost:7860/ws"/>
      
      <!-- 如果桥接失败 -->
      <action application="playback" data="ivr/ivr-service_not_working.wav"/>
    </condition>
  </extension>
</include>
